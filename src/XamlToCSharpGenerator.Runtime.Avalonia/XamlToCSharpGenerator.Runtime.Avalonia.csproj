<Project Sdk="Microsoft.NET.Sdk">
  <PropertyGroup>
    <TargetFrameworks>net6.0;net8.0;net10.0</TargetFrameworks>
    <IsPackable>true</IsPackable>
    <PackageId>XamlToCSharpGenerator.Runtime.Avalonia</PackageId>
    <Description>Avalonia runtime loader, bootstrap, and hot-reload integration for source-generated XAML.</Description>
    <PackageTags>$(PackageTags);avalonia;hot-reload;loader;runtime</PackageTags>
  </PropertyGroup>

  <ItemGroup Condition="'$(ApiDocumentationBuild)' != 'true'">
    <ProjectReference Include="../XamlToCSharpGenerator.Runtime.Core/XamlToCSharpGenerator.Runtime.Core.csproj" />
  </ItemGroup>

  <ItemGroup Condition="'$(ApiDocumentationBuild)' != 'true' and '$(TargetFramework)' == 'net10.0'">
    <ProjectReference Include="../XamlToCSharpGenerator.Editor.Avalonia/XamlToCSharpGenerator.Editor.Avalonia.csproj">
      <Aliases>axeditor</Aliases>
    </ProjectReference>
  </ItemGroup>

  <ItemGroup Condition="'$(ApiDocumentationBuild)' == 'true'">
    <Reference Include="XamlToCSharpGenerator.Runtime.Core">
      <HintPath>..\XamlToCSharpGenerator.Runtime.Core\bin\$(Configuration)\$(TargetFramework)\XamlToCSharpGenerator.Runtime.Core.dll</HintPath>
    </Reference>
  </ItemGroup>

  <ItemGroup>
    <PackageReference Include="Avalonia" Version="11.3.12" />
    <PackageReference Include="Avalonia.Markup.Xaml.Loader" Version="11.3.12" />
  </ItemGroup>

  <ItemGroup Condition="'$(TargetFramework)' == 'net10.0'">
    <PackageReference Include="Avalonia.AvaloniaEdit" Version="11.4.0" />
  </ItemGroup>

  <ItemGroup>
    <InternalsVisibleTo Include="XamlToCSharpGenerator.Tests" />
  </ItemGroup>
</Project>
