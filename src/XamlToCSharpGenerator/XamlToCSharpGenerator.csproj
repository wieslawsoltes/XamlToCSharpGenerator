          Visible="false" />
    <None Include="..\XamlToCSharpGenerator.Build.Tasks\bin\$(Configuration)\netstandard2.0\System.Buffers.dll"
          Pack="true"
          PackagePath="buildTransitive/System.Buffers.dll"
          Visible="false" />
    <None Include="..\XamlToCSharpGenerator.Build.Tasks\bin\$(Configuration)\netstandard2.0\System.Collections.Immutable.dll"
          Pack="true"
