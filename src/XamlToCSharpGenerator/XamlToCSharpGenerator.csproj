<Project Sdk="Microsoft.NET.Sdk">
  <PropertyGroup>
    <TargetFramework>net10.0</TargetFramework>
    <IsPackable>true</IsPackable>
    <IncludeBuildOutput>false</IncludeBuildOutput>
    <NoWarn>$(NoWarn);NU5128;NU5130</NoWarn>
    <PackageId>XamlToCSharpGenerator</PackageId>
    <Description>Single-package distribution for the Avalonia source-generated XAML compiler backend and runtime bootstrap.</Description>
    <PackageTags>$(PackageTags);build;compiler;generator;runtime</PackageTags>
    <BundledAnalyzerTargetFramework>netstandard2.0</BundledAnalyzerTargetFramework>
    <BundledAssetNestedBuildRemoveProperties>TargetFramework;TargetFrameworks;BundledAnalyzerTargetFramework;MSBuildProjectExtensionsPath;BaseIntermediateOutputPath;BaseOutputPath;IntermediateOutputPath;OutputPath;OutDir;RuntimeIdentifier</BundledAssetNestedBuildRemoveProperties>
  </PropertyGroup>

  <ItemGroup>
