          Pack="true"
          PackagePath="buildTransitive/XamlToCSharpGenerator.props"
          Visible="false" />
    <None Include="..\XamlToCSharpGenerator.Build\buildTransitive\XamlToCSharpGenerator.Build.targets"
          Pack="true"
          PackagePath="buildTransitive/XamlToCSharpGenerator.targets"
          Visible="false" />
    <None Include="..\XamlToCSharpGenerator.Build.Tasks\bin\$(Configuration)\netstandard2.0\XamlToCSharpGenerator.Build.Tasks.dll"
