          Visible="false" />
    <None Include="..\XamlToCSharpGenerator.Build.Tasks\bin\$(Configuration)\netstandard2.0\System.Memory.dll"
          Pack="true"
          PackagePath="buildTransitive/System.Memory.dll"
          Visible="false" />
    <None Include="..\XamlToCSharpGenerator.Build.Tasks\bin\$(Configuration)\netstandard2.0\System.Reflection.Metadata.dll"
