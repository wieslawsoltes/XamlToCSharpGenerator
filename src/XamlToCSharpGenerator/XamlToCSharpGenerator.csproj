      <_BundledAssetProjectToRestore Include="..\XamlToCSharpGenerator.Build.Tasks\XamlToCSharpGenerator.Build.Tasks.csproj" />
      <_BundledAssetProjectToRestore Include="..\XamlToCSharpGenerator.MiniLanguageParsing\XamlToCSharpGenerator.MiniLanguageParsing.csproj" />
      <_BundledAssetProjectToRestore Include="..\XamlToCSharpGenerator.Core\XamlToCSharpGenerator.Core.csproj" />
      <_BundledAssetProjectToRestore Include="..\XamlToCSharpGenerator.Compiler\XamlToCSharpGenerator.Compiler.csproj" />
      <_BundledAssetProjectToRestore Include="..\XamlToCSharpGenerator.Framework.Abstractions\XamlToCSharpGenerator.Framework.Abstractions.csproj" />
      <_BundledAssetProjectToRestore Include="..\XamlToCSharpGenerator.ExpressionSemantics\XamlToCSharpGenerator.ExpressionSemantics.csproj" />
      <_BundledAssetProjectToRestore Include="..\XamlToCSharpGenerator.Avalonia\XamlToCSharpGenerator.Avalonia.csproj" />
      <_BundledAssetProjectToRestore Include="..\XamlToCSharpGenerator.NoUi\XamlToCSharpGenerator.NoUi.csproj" />
      <_BundledAssetProjectToRestore Include="..\XamlToCSharpGenerator.Generator\XamlToCSharpGenerator.Generator.csproj" />
      <_BundledAssetProjectToRestore Include="..\XamlToCSharpGenerator.Runtime.Core\XamlToCSharpGenerator.Runtime.Core.csproj" />
      <_BundledAssetProjectToRestore Include="..\XamlToCSharpGenerator.RemoteProtocol\XamlToCSharpGenerator.RemoteProtocol.csproj" />
      <_BundledAssetProjectToRestore Include="..\XamlToCSharpGenerator.Runtime.Avalonia\XamlToCSharpGenerator.Runtime.Avalonia.csproj" />
      <_BundledAssetProjectToRestore Include="..\XamlToCSharpGenerator.Runtime\XamlToCSharpGenerator.Runtime.csproj" />
    </ItemGroup>

    <MSBuild Projects="@(_BundledAssetProjectToRestore)"
             Targets="Restore"
             BuildInParallel="true"
             RemoveProperties="$(BundledAssetNestedBuildRemoveProperties)"
             Properties="Configuration=$(Configuration);DesignTimeBuild=false;BuildingProject=false;GenerateDocumentationFile=false" />
    <MSBuild Projects="..\XamlToCSharpGenerator.Build.Tasks\XamlToCSharpGenerator.Build.Tasks.csproj"
             Targets="Build"
             BuildInParallel="false"
             RemoveProperties="$(BundledAssetNestedBuildRemoveProperties)"
             Properties="Configuration=$(Configuration);GenerateDocumentationFile=false" />
