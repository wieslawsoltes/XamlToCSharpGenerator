<Project Sdk="Microsoft.NET.Sdk">
  <PropertyGroup>
    <TargetFramework>net10.0</TargetFramework>
    <IsPackable>true</IsPackable>
    <IncludeBuildOutput>false</IncludeBuildOutput>
    <NoWarn>$(NoWarn);NU5128;NU5130</NoWarn>
    <PackageId>XamlToCSharpGenerator</PackageId>
    <Description>Single-package distribution for the Avalonia source-generated XAML compiler backend and runtime bootstrap.</Description>
    <PackageTags>$(PackageTags);build;compiler;generator;runtime</PackageTags>
    <BundledAnalyzerTargetFramework>netstandard2.0</BundledAnalyzerTargetFramework>
  </PropertyGroup>

  <ItemGroup>
    <None Include="..\XamlToCSharpGenerator.Build\buildTransitive\XamlToCSharpGenerator.Build.props"
          Pack="true"
          PackagePath="buildTransitive/XamlToCSharpGenerator.props"
          Visible="false" />
    <None Include="..\XamlToCSharpGenerator.Build\buildTransitive\XamlToCSharpGenerator.Build.targets"
          Pack="true"
          PackagePath="buildTransitive/XamlToCSharpGenerator.targets"
          Visible="false" />
  </ItemGroup>

  <ItemGroup>
    <None Include="..\XamlToCSharpGenerator.Runtime.Core\bin\$(Configuration)\net10.0\XamlToCSharpGenerator.Runtime.Core.dll"
          Pack="true"
          PackagePath="lib/net10.0"
          Visible="false" />
    <None Include="..\XamlToCSharpGenerator.Runtime.Avalonia\bin\$(Configuration)\net10.0\XamlToCSharpGenerator.Runtime.Avalonia.dll"
          Pack="true"
          PackagePath="lib/net10.0"
          Visible="false" />
    <None Include="..\XamlToCSharpGenerator.Runtime\bin\$(Configuration)\net10.0\XamlToCSharpGenerator.Runtime.dll"
          Pack="true"
          PackagePath="lib/net10.0"
          Visible="false" />
  </ItemGroup>

  <ItemGroup>
    <None Include="..\XamlToCSharpGenerator.Generator\bin\$(Configuration)\$(BundledAnalyzerTargetFramework)\XamlToCSharpGenerator.Generator.dll"
          Pack="true"
          PackagePath="analyzers/dotnet/cs"
          Visible="false" />
    <None Include="..\XamlToCSharpGenerator.Core\bin\$(Configuration)\$(BundledAnalyzerTargetFramework)\XamlToCSharpGenerator.Core.dll"
          Pack="true"
          PackagePath="analyzers/dotnet/cs"
          Visible="false" />
    <None Include="..\XamlToCSharpGenerator.Compiler\bin\$(Configuration)\$(BundledAnalyzerTargetFramework)\XamlToCSharpGenerator.Compiler.dll"
          Pack="true"
          PackagePath="analyzers/dotnet/cs"
          Visible="false" />
    <None Include="..\XamlToCSharpGenerator.Framework.Abstractions\bin\$(Configuration)\$(BundledAnalyzerTargetFramework)\XamlToCSharpGenerator.Framework.Abstractions.dll"
          Pack="true"
          PackagePath="analyzers/dotnet/cs"
          Visible="false" />
    <None Include="..\XamlToCSharpGenerator.Avalonia\bin\$(Configuration)\$(BundledAnalyzerTargetFramework)\XamlToCSharpGenerator.Avalonia.dll"
          Pack="true"
          PackagePath="analyzers/dotnet/cs"
          Visible="false" />
    <None Include="..\XamlToCSharpGenerator.MiniLanguageParsing\bin\$(Configuration)\$(BundledAnalyzerTargetFramework)\XamlToCSharpGenerator.MiniLanguageParsing.dll"
          Pack="true"
          PackagePath="analyzers/dotnet/cs"
          Visible="false" />
    <None Include="..\XamlToCSharpGenerator.ExpressionSemantics\bin\$(Configuration)\$(BundledAnalyzerTargetFramework)\XamlToCSharpGenerator.ExpressionSemantics.dll"
          Pack="true"
          PackagePath="analyzers/dotnet/cs"
          Visible="false" />
    <None Include="..\XamlToCSharpGenerator.NoUi\bin\$(Configuration)\$(BundledAnalyzerTargetFramework)\XamlToCSharpGenerator.NoUi.dll"
          Pack="true"
          PackagePath="analyzers/dotnet/cs"
          Visible="false" />
  </ItemGroup>

  <Target Name="BuildBundledAssets" BeforeTargets="_GetPackageFiles;Pack">
    <MSBuild Projects="..\XamlToCSharpGenerator.MiniLanguageParsing\XamlToCSharpGenerator.MiniLanguageParsing.csproj"
             Targets="Build"
             Properties="Configuration=$(Configuration);GenerateDocumentationFile=false;NoWarn=CS1591;RS2008" />
    <MSBuild Projects="..\XamlToCSharpGenerator.Core\XamlToCSharpGenerator.Core.csproj"
             Targets="Build"
             Properties="Configuration=$(Configuration);GenerateDocumentationFile=false;NoWarn=CS1591;RS2008" />
    <MSBuild Projects="..\XamlToCSharpGenerator.Compiler\XamlToCSharpGenerator.Compiler.csproj"
             Targets="Build"
             Properties="Configuration=$(Configuration);GenerateDocumentationFile=false;NoWarn=CS1591;RS2008" />
    <MSBuild Projects="..\XamlToCSharpGenerator.Framework.Abstractions\XamlToCSharpGenerator.Framework.Abstractions.csproj"
             Targets="Build"
             Properties="Configuration=$(Configuration);GenerateDocumentationFile=false;NoWarn=CS1591;RS2008" />
    <MSBuild Projects="..\XamlToCSharpGenerator.ExpressionSemantics\XamlToCSharpGenerator.ExpressionSemantics.csproj"
             Targets="Build"
             Properties="Configuration=$(Configuration);GenerateDocumentationFile=false;NoWarn=CS1591;RS2008" />
    <MSBuild Projects="..\XamlToCSharpGenerator.Avalonia\XamlToCSharpGenerator.Avalonia.csproj"
             Targets="Build"
             Properties="Configuration=$(Configuration);GenerateDocumentationFile=false;NoWarn=CS1591" />
    <MSBuild Projects="..\XamlToCSharpGenerator.NoUi\XamlToCSharpGenerator.NoUi.csproj"
             Targets="Build"
             Properties="Configuration=$(Configuration);GenerateDocumentationFile=false;NoWarn=CS1591" />
    <MSBuild Projects="..\XamlToCSharpGenerator.Generator\XamlToCSharpGenerator.Generator.csproj"
             Targets="Build"
             Properties="Configuration=$(Configuration);GenerateDocumentationFile=false;NoWarn=CS1591;RS1036" />
    <MSBuild Projects="..\XamlToCSharpGenerator.Runtime.Core\XamlToCSharpGenerator.Runtime.Core.csproj"
             Targets="Build"
             Properties="Configuration=$(Configuration);GenerateDocumentationFile=false;NoWarn=CS1591" />
    <MSBuild Projects="..\XamlToCSharpGenerator.Runtime.Avalonia\XamlToCSharpGenerator.Runtime.Avalonia.csproj"
             Targets="Build"
             Properties="Configuration=$(Configuration);GenerateDocumentationFile=false;NoWarn=CS1591" />
    <MSBuild Projects="..\XamlToCSharpGenerator.Runtime\XamlToCSharpGenerator.Runtime.csproj"
             Targets="Build"
             Properties="Configuration=$(Configuration);GenerateDocumentationFile=false;NoWarn=CS1591" />
  </Target>
</Project>
