<Project Sdk="Microsoft.NET.Sdk">
  <PropertyGroup>
    <TargetFrameworks>net6.0;net8.0;net10.0</TargetFrameworks>
    <IsPackable>true</IsPackable>
    <PackageId>XamlToCSharpGenerator.Runtime</PackageId>
    <Description>Compatibility runtime package that composes Runtime.Core and Runtime.Avalonia.</Description>
    <PackageTags>$(PackageTags);hot-reload;loader;runtime</PackageTags>
  </PropertyGroup>

  <ItemGroup>
    <ProjectReference Include="../XamlToCSharpGenerator.Runtime.Core/XamlToCSharpGenerator.Runtime.Core.csproj" />
    <ProjectReference Include="../XamlToCSharpGenerator.Runtime.Avalonia/XamlToCSharpGenerator.Runtime.Avalonia.csproj" />
  </ItemGroup>
</Project>
