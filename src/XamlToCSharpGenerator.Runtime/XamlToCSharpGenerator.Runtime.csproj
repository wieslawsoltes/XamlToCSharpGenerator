<Project Sdk="Microsoft.NET.Sdk">
  <PropertyGroup>
    <TargetFramework>net10.0</TargetFramework>
    <IsPackable>true</IsPackable>
    <PackageId>XamlToCSharpGenerator.Runtime</PackageId>
    <Description>Runtime registry and bootstrap extensions for source-generated Avalonia XAML.</Description>
  </PropertyGroup>

  <ItemGroup>
    <PackageReference Include="Avalonia" Version="11.3.12" />
    <PackageReference Include="Microsoft.CodeAnalysis.CSharp" Version="4.10.0" />
  </ItemGroup>

  <ItemGroup>
    <ProjectReference Include="../XamlToCSharpGenerator.Core/XamlToCSharpGenerator.Core.csproj" />
    <ProjectReference Include="../XamlToCSharpGenerator.Avalonia/XamlToCSharpGenerator.Avalonia.csproj" />
  </ItemGroup>
</Project>
