<Project Sdk="Microsoft.NET.Sdk">
  <PropertyGroup>
    <TargetFrameworks>net6.0;net8.0;net10.0</TargetFrameworks>
    <IsPackable>true</IsPackable>
    <PackageId>XamlToCSharpGenerator.Runtime.Core</PackageId>
    <Description>Framework-agnostic runtime registries, URI mapping, and hot-reload contracts for source-generated XAML.</Description>
    <PackageTags>$(PackageTags);hot-reload;registries;runtime</PackageTags>
  </PropertyGroup>

  <ItemGroup Condition="'$(ApiDocumentationBuild)' == 'true'">
    <Compile Remove="IgnoresAccessChecksToAttribute.cs" />
  </ItemGroup>

  <ItemGroup>
    <InternalsVisibleTo Include="XamlToCSharpGenerator.Runtime.Avalonia" />
    <InternalsVisibleTo Include="XamlToCSharpGenerator.Tests" />
  </ItemGroup>
</Project>
