<Project>
  <PropertyGroup>
    <AvaloniaXamlCompilerBackend Condition="'$(AvaloniaXamlCompilerBackend)' == ''">XamlIl</AvaloniaXamlCompilerBackend>
    <AvaloniaSourceGenCompilerEnabled Condition="'$(AvaloniaSourceGenCompilerEnabled)' == ''">false</AvaloniaSourceGenCompilerEnabled>
    <AvaloniaSourceGenUseCompiledBindingsByDefault Condition="'$(AvaloniaSourceGenUseCompiledBindingsByDefault)' == ''">false</AvaloniaSourceGenUseCompiledBindingsByDefault>
    <AvaloniaSourceGenCSharpExpressionsEnabled Condition="'$(AvaloniaSourceGenCSharpExpressionsEnabled)' == ''">true</AvaloniaSourceGenCSharpExpressionsEnabled>
    <AvaloniaSourceGenImplicitCSharpExpressionsEnabled Condition="'$(AvaloniaSourceGenImplicitCSharpExpressionsEnabled)' == ''">true</AvaloniaSourceGenImplicitCSharpExpressionsEnabled>
    <AvaloniaSourceGenCreateSourceInfo Condition="'$(AvaloniaSourceGenCreateSourceInfo)' == ''">false</AvaloniaSourceGenCreateSourceInfo>
    <AvaloniaSourceGenStrictMode Condition="'$(AvaloniaSourceGenStrictMode)' == ''">false</AvaloniaSourceGenStrictMode>
    <AvaloniaSourceGenHotReloadEnabled Condition="'$(AvaloniaSourceGenHotReloadEnabled)' == ''">true</AvaloniaSourceGenHotReloadEnabled>
    <AvaloniaSourceGenHotReloadErrorResilienceEnabled Condition="'$(AvaloniaSourceGenHotReloadErrorResilienceEnabled)' == ''">true</AvaloniaSourceGenHotReloadErrorResilienceEnabled>
    <AvaloniaSourceGenIdeHotReloadEnabled Condition="'$(AvaloniaSourceGenIdeHotReloadEnabled)' == ''">true</AvaloniaSourceGenIdeHotReloadEnabled>
    <AvaloniaSourceGenHotDesignEnabled Condition="'$(AvaloniaSourceGenHotDesignEnabled)' == ''">false</AvaloniaSourceGenHotDesignEnabled>
    <AvaloniaSourceGenTracePasses Condition="'$(AvaloniaSourceGenTracePasses)' == ''">false</AvaloniaSourceGenTracePasses>
    <AvaloniaSourceGenMetricsEnabled Condition="'$(AvaloniaSourceGenMetricsEnabled)' == ''">false</AvaloniaSourceGenMetricsEnabled>
    <AvaloniaSourceGenMetricsDetailed Condition="'$(AvaloniaSourceGenMetricsDetailed)' == ''">false</AvaloniaSourceGenMetricsDetailed>
    <AvaloniaSourceGenTypeResolutionCompatibilityFallbackEnabled Condition="'$(AvaloniaSourceGenTypeResolutionCompatibilityFallbackEnabled)' == ''">true</AvaloniaSourceGenTypeResolutionCompatibilityFallbackEnabled>
    <AvaloniaSourceGenAllowImplicitXmlnsDeclaration Condition="'$(AvaloniaSourceGenAllowImplicitXmlnsDeclaration)' == ''">false</AvaloniaSourceGenAllowImplicitXmlnsDeclaration>
    <AvaloniaSourceGenImplicitStandardXmlnsPrefixesEnabled Condition="'$(AvaloniaSourceGenImplicitStandardXmlnsPrefixesEnabled)' == ''">true</AvaloniaSourceGenImplicitStandardXmlnsPrefixesEnabled>
    <AvaloniaSourceGenImplicitDefaultXmlns Condition="'$(AvaloniaSourceGenImplicitDefaultXmlns)' == ''">https://github.com/avaloniaui</AvaloniaSourceGenImplicitDefaultXmlns>
    <AvaloniaSourceGenInferClassFromPath Condition="'$(AvaloniaSourceGenInferClassFromPath)' == ''">false</AvaloniaSourceGenInferClassFromPath>
    <AvaloniaSourceGenImplicitProjectNamespacesEnabled Condition="'$(AvaloniaSourceGenImplicitProjectNamespacesEnabled)' == ''">false</AvaloniaSourceGenImplicitProjectNamespacesEnabled>
    <AvaloniaSourceGenGlobalXmlnsPrefixes Condition="'$(AvaloniaSourceGenGlobalXmlnsPrefixes)' == ''"></AvaloniaSourceGenGlobalXmlnsPrefixes>
    <AvaloniaSourceGenTransformRules Condition="'$(AvaloniaSourceGenTransformRules)' == ''"></AvaloniaSourceGenTransformRules>
  </PropertyGroup>

  <ItemGroup>
    <CompilerVisibleItemMetadata Include="AdditionalFiles" MetadataName="SourceItemGroup" />
    <CompilerVisibleItemMetadata Include="AdditionalFiles" MetadataName="TargetPath" />
    <CompilerVisibleProperty Include="AvaloniaXamlCompilerBackend" />
    <CompilerVisibleProperty Include="AvaloniaSourceGenCompilerEnabled" />
    <CompilerVisibleProperty Include="AvaloniaSourceGenUseCompiledBindingsByDefault" />
    <CompilerVisibleProperty Include="AvaloniaSourceGenCSharpExpressionsEnabled" />
    <CompilerVisibleProperty Include="AvaloniaSourceGenImplicitCSharpExpressionsEnabled" />
    <CompilerVisibleProperty Include="AvaloniaSourceGenCreateSourceInfo" />
    <CompilerVisibleProperty Include="AvaloniaSourceGenStrictMode" />
    <CompilerVisibleProperty Include="AvaloniaSourceGenHotReloadEnabled" />
    <CompilerVisibleProperty Include="AvaloniaSourceGenHotReloadErrorResilienceEnabled" />
    <CompilerVisibleProperty Include="AvaloniaSourceGenIdeHotReloadEnabled" />
    <CompilerVisibleProperty Include="AvaloniaSourceGenHotDesignEnabled" />
    <CompilerVisibleProperty Include="AvaloniaSourceGenTracePasses" />
    <CompilerVisibleProperty Include="AvaloniaSourceGenMetricsEnabled" />
    <CompilerVisibleProperty Include="AvaloniaSourceGenMetricsDetailed" />
    <CompilerVisibleProperty Include="AvaloniaSourceGenTypeResolutionCompatibilityFallbackEnabled" />
    <CompilerVisibleProperty Include="AvaloniaSourceGenAllowImplicitXmlnsDeclaration" />
    <CompilerVisibleProperty Include="AvaloniaSourceGenImplicitStandardXmlnsPrefixesEnabled" />
    <CompilerVisibleProperty Include="AvaloniaSourceGenImplicitDefaultXmlns" />
    <CompilerVisibleProperty Include="AvaloniaSourceGenInferClassFromPath" />
    <CompilerVisibleProperty Include="AvaloniaSourceGenImplicitProjectNamespacesEnabled" />
    <CompilerVisibleProperty Include="AvaloniaSourceGenGlobalXmlnsPrefixes" />
    <CompilerVisibleProperty Include="AvaloniaSourceGenTransformRules" />
    <CompilerVisibleProperty Include="RootNamespace" />
    <CompilerVisibleProperty Include="DotNetWatchBuild" />
    <CompilerVisibleProperty Include="BuildingInsideVisualStudio" />
    <CompilerVisibleProperty Include="BuildingByReSharper" />
    <CompilerVisibleProperty Include="AvaloniaNameGeneratorIsEnabled" />
  </ItemGroup>
</Project>
