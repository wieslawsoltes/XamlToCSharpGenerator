<Project>
  <!-- Resolve SourceGen backend switches in .targets so project-level properties are already available. -->
  <PropertyGroup>
    <XamlSourceGenBackend Condition="'$(XamlSourceGenBackend)' == '' and '$(AvaloniaXamlCompilerBackend)' != ''">$(AvaloniaXamlCompilerBackend)</XamlSourceGenBackend>
    <XamlSourceGenBackend Condition="'$(XamlSourceGenBackend)' == ''">XamlIl</XamlSourceGenBackend>
    <XamlSourceGenEnabled Condition="'$(XamlSourceGenEnabled)' == '' and '$(AvaloniaSourceGenCompilerEnabled)' != ''">$(AvaloniaSourceGenCompilerEnabled)</XamlSourceGenEnabled>
    <XamlSourceGenEnabled Condition="'$(XamlSourceGenEnabled)' == ''">false</XamlSourceGenEnabled>
    <XamlSourceGenEnabled Condition="'$(XamlSourceGenBackend)' == 'SourceGen'">true</XamlSourceGenEnabled>
    <_XamlSourceGenRequestedAdditionalFilesSourceItemGroup Condition="'$(_XamlSourceGenRequestedAdditionalFilesSourceItemGroup)' == ''">$(XamlSourceGenAdditionalFilesSourceItemGroup)</_XamlSourceGenRequestedAdditionalFilesSourceItemGroup>
    <_XamlSourceGenSupportedAdditionalFilesSourceItemGroup>AvaloniaXaml</_XamlSourceGenSupportedAdditionalFilesSourceItemGroup>
    <XamlSourceGenAdditionalFilesSourceItemGroup Condition="'$(XamlSourceGenAdditionalFilesSourceItemGroup)' == ''">AvaloniaXaml</XamlSourceGenAdditionalFilesSourceItemGroup>
    <_XamlSourceGenAdditionalFilesSourceItemGroupGuarded>false</_XamlSourceGenAdditionalFilesSourceItemGroupGuarded>
    <_XamlSourceGenAdditionalFilesSourceItemGroupGuarded Condition="'$(XamlSourceGenEnabled)' == 'true' and '$(_XamlSourceGenRequestedAdditionalFilesSourceItemGroup)' != '' and '$(_XamlSourceGenRequestedAdditionalFilesSourceItemGroup)' != '$(_XamlSourceGenSupportedAdditionalFilesSourceItemGroup)'">true</_XamlSourceGenAdditionalFilesSourceItemGroupGuarded>
    <XamlSourceGenAdditionalFilesSourceItemGroup Condition="'$(_XamlSourceGenAdditionalFilesSourceItemGroupGuarded)' == 'true'">$(_XamlSourceGenSupportedAdditionalFilesSourceItemGroup)</XamlSourceGenAdditionalFilesSourceItemGroup>
    <XamlSourceGenTransformRules Condition="'$(XamlSourceGenTransformRules)' == '' and '$(AvaloniaSourceGenTransformRules)' != ''">$(AvaloniaSourceGenTransformRules)</XamlSourceGenTransformRules>
    <XamlSourceGenTransformRuleItemGroup Condition="'$(XamlSourceGenTransformRuleItemGroup)' == ''">AvaloniaSourceGenTransformRule</XamlSourceGenTransformRuleItemGroup>
    <XamlSourceGenConfigurationPrecedence Condition="'$(XamlSourceGenConfigurationPrecedence)' == '' and '$(AvaloniaSourceGenConfigurationPrecedence)' != ''">$(AvaloniaSourceGenConfigurationPrecedence)</XamlSourceGenConfigurationPrecedence>
    <XamlSourceGenConfigurationPrecedence Condition="'$(XamlSourceGenConfigurationPrecedence)' == ''"></XamlSourceGenConfigurationPrecedence>
    <AvaloniaSourceGenTransformRules Condition="'$(AvaloniaSourceGenTransformRules)' == '' and '$(XamlSourceGenTransformRules)' != ''">$(XamlSourceGenTransformRules)</AvaloniaSourceGenTransformRules>
    <AvaloniaSourceGenConfigurationPrecedence Condition="'$(AvaloniaSourceGenConfigurationPrecedence)' == '' and '$(XamlSourceGenConfigurationPrecedence)' != ''">$(XamlSourceGenConfigurationPrecedence)</AvaloniaSourceGenConfigurationPrecedence>
    <AvaloniaXamlCompilerBackend>$(XamlSourceGenBackend)</AvaloniaXamlCompilerBackend>
    <AvaloniaSourceGenCompilerEnabled>$(XamlSourceGenEnabled)</AvaloniaSourceGenCompilerEnabled>
    <XamlSourceGenIlWeavingEnabled Condition="'$(XamlSourceGenIlWeavingEnabled)' == '' and '$(AvaloniaSourceGenIlWeavingEnabled)' != ''">$(AvaloniaSourceGenIlWeavingEnabled)</XamlSourceGenIlWeavingEnabled>
    <XamlSourceGenIlWeavingEnabled Condition="'$(XamlSourceGenIlWeavingEnabled)' == ''">true</XamlSourceGenIlWeavingEnabled>
    <XamlSourceGenIlWeavingStrict Condition="'$(XamlSourceGenIlWeavingStrict)' == '' and '$(AvaloniaSourceGenIlWeavingStrict)' != ''">$(AvaloniaSourceGenIlWeavingStrict)</XamlSourceGenIlWeavingStrict>
    <XamlSourceGenIlWeavingStrict Condition="'$(XamlSourceGenIlWeavingStrict)' == ''">true</XamlSourceGenIlWeavingStrict>
    <XamlSourceGenIlWeavingVerbose Condition="'$(XamlSourceGenIlWeavingVerbose)' == '' and '$(AvaloniaSourceGenIlWeavingVerbose)' != ''">$(AvaloniaSourceGenIlWeavingVerbose)</XamlSourceGenIlWeavingVerbose>
    <XamlSourceGenIlWeavingVerbose Condition="'$(XamlSourceGenIlWeavingVerbose)' == ''">false</XamlSourceGenIlWeavingVerbose>
    <AvaloniaSourceGenIlWeavingEnabled Condition="'$(AvaloniaSourceGenIlWeavingEnabled)' == ''">$(XamlSourceGenIlWeavingEnabled)</AvaloniaSourceGenIlWeavingEnabled>
    <AvaloniaSourceGenIlWeavingStrict Condition="'$(AvaloniaSourceGenIlWeavingStrict)' == ''">$(XamlSourceGenIlWeavingStrict)</AvaloniaSourceGenIlWeavingStrict>
    <AvaloniaSourceGenIlWeavingVerbose Condition="'$(AvaloniaSourceGenIlWeavingVerbose)' == ''">$(XamlSourceGenIlWeavingVerbose)</AvaloniaSourceGenIlWeavingVerbose>
    <_XamlSourceGenPackagedIlWeaverTaskAssemblyPath Condition="'$(_XamlSourceGenPackagedIlWeaverTaskAssemblyPath)' == ''">$([System.IO.Path]::GetFullPath('$(MSBuildThisFileDirectory)XamlToCSharpGenerator.Build.Tasks.dll'))</_XamlSourceGenPackagedIlWeaverTaskAssemblyPath>
    <_XamlSourceGenLocalIlWeaverProjectPath Condition="'$(_XamlSourceGenLocalIlWeaverProjectPath)' == ''">$([System.IO.Path]::GetFullPath('$(MSBuildThisFileDirectory)..\..\XamlToCSharpGenerator.Build.Tasks\XamlToCSharpGenerator.Build.Tasks.csproj'))</_XamlSourceGenLocalIlWeaverProjectPath>
    <_XamlSourceGenLocalIlWeaverTaskAssemblyPath Condition="'$(_XamlSourceGenLocalIlWeaverTaskAssemblyPath)' == ''">$([System.IO.Path]::GetFullPath('$(MSBuildThisFileDirectory)..\..\XamlToCSharpGenerator.Build.Tasks\bin\$(Configuration)\netstandard2.0\XamlToCSharpGenerator.Build.Tasks.dll'))</_XamlSourceGenLocalIlWeaverTaskAssemblyPath>
    <_XamlSourceGenLocalIlWeaverAssetsPath Condition="'$(_XamlSourceGenLocalIlWeaverAssetsPath)' == ''">$([System.IO.Path]::GetFullPath('$(MSBuildThisFileDirectory)..\..\XamlToCSharpGenerator.Build.Tasks\obj\project.assets.json'))</_XamlSourceGenLocalIlWeaverAssetsPath>
    <XamlSourceGenIlWeaverTaskAssemblyPath Condition="'$(XamlSourceGenIlWeaverTaskAssemblyPath)' == '' and Exists('$(_XamlSourceGenPackagedIlWeaverTaskAssemblyPath)')">$(_XamlSourceGenPackagedIlWeaverTaskAssemblyPath)</XamlSourceGenIlWeaverTaskAssemblyPath>
    <XamlSourceGenIlWeaverTaskAssemblyPath Condition="'$(XamlSourceGenIlWeaverTaskAssemblyPath)' == '' and Exists('$(_XamlSourceGenLocalIlWeaverProjectPath)')">$(_XamlSourceGenLocalIlWeaverTaskAssemblyPath)</XamlSourceGenIlWeaverTaskAssemblyPath>
    <_XamlSourceGenIsIosTarget>false</_XamlSourceGenIsIosTarget>
    <_XamlSourceGenIsIosTarget Condition="'$(TargetPlatformIdentifier)' == 'iOS' or '$(TargetPlatformIdentifier)' == 'ios'">true</_XamlSourceGenIsIosTarget>
    <_XamlSourceGenIsIosTarget Condition="'$(_XamlSourceGenIsIosTarget)' != 'true' and '$(TargetFramework)' != '' and $([System.String]::Copy('$(TargetFramework)').Contains('-ios'))">true</_XamlSourceGenIsIosTarget>
    <_XamlSourceGenIsIosSimulator>false</_XamlSourceGenIsIosSimulator>
    <_XamlSourceGenIsIosSimulator Condition="'$(_XamlSourceGenIsIosTarget)' == 'true' and '$(RuntimeIdentifier)' != '' and $([System.String]::Copy('$(RuntimeIdentifier)').Contains('iossimulator'))">true</_XamlSourceGenIsIosSimulator>
    <_XamlSourceGenIsIosSimulator Condition="'$(_XamlSourceGenIsIosSimulator)' != 'true' and '$(_XamlSourceGenIsIosTarget)' == 'true' and ('$(Platform)' == 'iPhoneSimulator' or '$(PlatformTarget)' == 'iPhoneSimulator')">true</_XamlSourceGenIsIosSimulator>
    <AvaloniaSourceGenIosHotReloadEnabled Condition="'$(AvaloniaSourceGenIosHotReloadEnabled)' == '' and '$(_XamlSourceGenIsIosTarget)' == 'true' and '$(Configuration)' == 'Debug'">true</AvaloniaSourceGenIosHotReloadEnabled>
    <AvaloniaSourceGenIosHotReloadEnabled Condition="'$(AvaloniaSourceGenIosHotReloadEnabled)' == ''">false</AvaloniaSourceGenIosHotReloadEnabled>
    <AvaloniaSourceGenDotNetWatchXamlBuildTriggersEnabled Condition="'$(AvaloniaSourceGenDotNetWatchXamlBuildTriggersEnabled)' == ''">false</AvaloniaSourceGenDotNetWatchXamlBuildTriggersEnabled>
    <AvaloniaSourceGenIosHotReloadUseInterpreter Condition="'$(AvaloniaSourceGenIosHotReloadUseInterpreter)' == '' and '$(AvaloniaSourceGenIosHotReloadEnabled)' == 'true'">true</AvaloniaSourceGenIosHotReloadUseInterpreter>
    <AvaloniaSourceGenIosHotReloadUseInterpreter Condition="'$(AvaloniaSourceGenIosHotReloadUseInterpreter)' == ''">false</AvaloniaSourceGenIosHotReloadUseInterpreter>
    <_XamlSourceGenEnableIosDotNetWatchHotReload>false</_XamlSourceGenEnableIosDotNetWatchHotReload>
    <_XamlSourceGenEnableIosDotNetWatchHotReload Condition="'$(_XamlSourceGenIsIosTarget)' == 'true' and '$(Configuration)' == 'Debug' and '$(AvaloniaSourceGenHotReloadEnabled)' == 'true' and '$(AvaloniaSourceGenIosHotReloadEnabled)' == 'true'">true</_XamlSourceGenEnableIosDotNetWatchHotReload>
    <_XamlSourceGenEnableDotNetWatchXamlBuildTriggers>false</_XamlSourceGenEnableDotNetWatchXamlBuildTriggers>
    <_XamlSourceGenEnableDotNetWatchXamlBuildTriggers Condition="'$(DotNetWatchBuild)' == 'true' and '$(AvaloniaSourceGenHotReloadEnabled)' == 'true' and '$(AvaloniaSourceGenIdeHotReloadEnabled)' == 'true' and '$(AvaloniaSourceGenDotNetWatchXamlBuildTriggersEnabled)' == 'true'">true</_XamlSourceGenEnableDotNetWatchXamlBuildTriggers>
    <_XamlSourceGenEnableDotNetWatchXamlBuildTriggers Condition="'$(_XamlSourceGenEnableIosDotNetWatchHotReload)' == 'true' and '$(AvaloniaSourceGenIosDotNetWatchXamlBuildTriggersEnabled)' == 'true'">true</_XamlSourceGenEnableDotNetWatchXamlBuildTriggers>
    <_XamlSourceGenEnableDotNetWatchXamlCompileInputs>true</_XamlSourceGenEnableDotNetWatchXamlCompileInputs>
    <_XamlSourceGenEnableDotNetWatchXamlCompileInputs Condition="'$(DotNetWatchBuild)' == 'true' and '$(_XamlSourceGenEnableDotNetWatchXamlBuildTriggers)' != 'true' and '$(AvaloniaSourceGenHotReloadEnabled)' == 'true' and '$(AvaloniaSourceGenIdeHotReloadEnabled)' == 'true'">false</_XamlSourceGenEnableDotNetWatchXamlCompileInputs>
    <CustomCollectWatchItems>$(CustomCollectWatchItems);XamlToCSharpGenerator_FilterDotNetWatchItems</CustomCollectWatchItems>
    <UseInterpreter Condition="'$(_XamlSourceGenEnableIosDotNetWatchHotReload)' == 'true' and '$(AvaloniaSourceGenIosHotReloadUseInterpreter)' == 'true' and '$(UseInterpreter)' == ''">true</UseInterpreter>
    <MtouchInterpreter Condition="'$(_XamlSourceGenEnableIosDotNetWatchHotReload)' == 'true' and '$(AvaloniaSourceGenIosHotReloadUseInterpreter)' == 'true' and '$(MtouchInterpreter)' == ''">all</MtouchInterpreter>
    <StartupHookSupport Condition="'$(_XamlSourceGenEnableIosDotNetWatchHotReload)' == 'true' and '$(AvaloniaSourceGenIosHotReloadForwardWatchEnvironment)' == 'true' and '$(AvaloniaSourceGenIosHotReloadForwardStartupHooks)' == 'true' and '$(AvaloniaSourceGenIosHotReloadEnableStartupHookSupport)' == 'true'">true</StartupHookSupport>
    <_XamlSourceGenHasDotNetStartupHooksVar>false</_XamlSourceGenHasDotNetStartupHooksVar>
    <_XamlSourceGenStartupHooksSuppressed>false</_XamlSourceGenStartupHooksSuppressed>
    <_XamlSourceGenHasDotNetWatchNamedPipeVar>false</_XamlSourceGenHasDotNetWatchNamedPipeVar>
    <_XamlSourceGenResolvedRemoteEndpoint>$(AvaloniaSourceGenHotReloadRemoteEndpoint)</_XamlSourceGenResolvedRemoteEndpoint>
    <_XamlSourceGenResolvedRemoteEndpoint Condition="'$(_XamlSourceGenResolvedRemoteEndpoint)' == '' and '$(_XamlSourceGenEnableIosDotNetWatchHotReload)' == 'true' and '$(_XamlSourceGenIsIosSimulator)' == 'true' and '$(AvaloniaSourceGenHotReloadRemoteAutoSimulatorEndpointEnabled)' == 'true'">tcp://127.0.0.1:$(AvaloniaSourceGenHotReloadRemotePort)</_XamlSourceGenResolvedRemoteEndpoint>
    <_XamlSourceGenRemoteEndpointWasAutoSelected>false</_XamlSourceGenRemoteEndpointWasAutoSelected>
    <_XamlSourceGenRemoteEndpointWasAutoSelected Condition="'$(_XamlSourceGenEnableIosDotNetWatchHotReload)' == 'true' and '$(AvaloniaSourceGenHotReloadRemoteEndpoint)' == '' and '$(_XamlSourceGenResolvedRemoteEndpoint)' != '' and '$(_XamlSourceGenIsIosSimulator)' == 'true' and '$(AvaloniaSourceGenHotReloadRemoteAutoSimulatorEndpointEnabled)' == 'true'">true</_XamlSourceGenRemoteEndpointWasAutoSelected>
    <_XamlSourceGenRequiresExplicitDeviceEndpoint>false</_XamlSourceGenRequiresExplicitDeviceEndpoint>
    <_XamlSourceGenRequiresExplicitDeviceEndpoint Condition="'$(_XamlSourceGenEnableIosDotNetWatchHotReload)' == 'true' and '$(_XamlSourceGenIsIosSimulator)' != 'true' and '$(AvaloniaSourceGenHotReloadRemoteRequireExplicitDeviceEndpoint)' == 'true' and '$(AvaloniaSourceGenIosHotReloadTransportMode)' != 'MetadataOnly' and '$(_XamlSourceGenResolvedRemoteEndpoint)' == ''">true</_XamlSourceGenRequiresExplicitDeviceEndpoint>
    <_XamlSourceGenEscapedAxsgRemoteEndpoint Condition="'$(_XamlSourceGenEnableIosDotNetWatchHotReload)' == 'true'">$([System.String]::Copy('$(_XamlSourceGenResolvedRemoteEndpoint)').Replace(';', '%3B'))</_XamlSourceGenEscapedAxsgRemoteEndpoint>
    <_XamlSourceGenMlaunchSetEnvArguments></_XamlSourceGenMlaunchSetEnvArguments>
    <_XamlSourceGenHasSetEnvArgs>false</_XamlSourceGenHasSetEnvArgs>
    <_XamlSourceGenHasDotNetWatchProxy>false</_XamlSourceGenHasDotNetWatchProxy>
    <_XamlSourceGenHasDotNetWatchProxy Condition="'$(AvaloniaSourceGenIosDotNetWatchProxyPath)' != '' and Exists('$(AvaloniaSourceGenIosDotNetWatchProxyPath)')">true</_XamlSourceGenHasDotNetWatchProxy>
  </PropertyGroup>

  <UsingTask TaskName="XamlToCSharpGenerator.Build.Tasks.RewriteAvaloniaLoaderCallsTask"
             AssemblyFile="$(XamlSourceGenIlWeaverTaskAssemblyPath)"
             Condition="'$(XamlSourceGenIlWeaverTaskAssemblyPath)' != ''" />

  <Target Name="XamlToCSharpGenerator_PrepareIosMlaunchWrapper"
          BeforeTargets="_ComputeMlaunchRunArguments;ComputeMlaunchRunArguments"
          DependsOnTargets="_DetectSdkLocations"
          Condition="'$(_XamlSourceGenEnableIosDotNetWatchHotReload)' == 'true' and '$(AvaloniaSourceGenIosHotReloadForwardWatchEnvironment)' == 'true'">
    <PropertyGroup>
      <_XamlSourceGenOriginalMlaunchPath Condition="'$(_XamlSourceGenOriginalMlaunchPath)' == '' and '$(MlaunchPath)' != ''">$(MlaunchPath)</_XamlSourceGenOriginalMlaunchPath>
      <_XamlSourceGenOriginalMlaunchPath Condition="'$(_XamlSourceGenOriginalMlaunchPath)' == '' and '$(_MlaunchPath)' != ''">$(_MlaunchPath)</_XamlSourceGenOriginalMlaunchPath>
      <_XamlSourceGenMlaunchWrapperPath Condition="'$(_XamlSourceGenMlaunchWrapperPath)' == ''">$(IntermediateOutputPath)axsg-mlaunch-wrapper.sh</_XamlSourceGenMlaunchWrapperPath>
      <_XamlSourceGenUseMlaunchWrapper>false</_XamlSourceGenUseMlaunchWrapper>
      <_XamlSourceGenUseMlaunchWrapper Condition="'$(_XamlSourceGenOriginalMlaunchPath)' != '' and '$(_XamlSourceGenMlaunchWrapperPath)' != '' and '$(_XamlSourceGenOriginalMlaunchPath)' != '$(_XamlSourceGenMlaunchWrapperPath)'">true</_XamlSourceGenUseMlaunchWrapper>
    </PropertyGroup>

    <ItemGroup Condition="'$(_XamlSourceGenUseMlaunchWrapper)' == 'true'">
      <_XamlSourceGenMlaunchWrapperLines Include="#!/usr/bin/env bash" />
      <_XamlSourceGenMlaunchWrapperLines Include="set -eo pipefail" />
      <_XamlSourceGenMlaunchWrapperLines Include="REAL_MLAUNCH=&quot;$(_XamlSourceGenOriginalMlaunchPath)&quot;" />
      <_XamlSourceGenMlaunchWrapperLines Include="declare -a AXSG_MLAUNCH_ENV_ARGS=()" />
      <_XamlSourceGenMlaunchWrapperLines Include="AXSG_PROXY_PID=&quot;&quot;" />
      <_XamlSourceGenMlaunchWrapperLines Include="AXSG_PROXY_ACTIVE=false" />
      <_XamlSourceGenMlaunchWrapperLines Include="axsg_export_simctl_child_env() { local name=&quot;$1&quot;; local value=&quot;${!name:-}&quot;; if [[ -n &quot;${value}&quot; ]]; then export &quot;SIMCTL_CHILD_${name}=${value}&quot;; fi; }" />
      <_XamlSourceGenMlaunchWrapperLines Include="axsg_export_simctl_child_env DOTNET_WATCH_HOTRELOAD_NAMEDPIPE_NAME" />
      <_XamlSourceGenMlaunchWrapperLines Include="axsg_export_simctl_child_env DOTNET_HOTRELOAD_NAMEDPIPE_NAME" />
      <_XamlSourceGenMlaunchWrapperLines Include="axsg_export_simctl_child_env AXSG_HOTRELOAD_TRACE" />
      <_XamlSourceGenMlaunchWrapperLines Include="if [[ -n &quot;${TMPDIR:-}&quot; ]]" />
      <_XamlSourceGenMlaunchWrapperLines Include="then export SIMCTL_CHILD_AXSG_DOTNET_WATCH_PIPE_DIRECTORY=${TMPDIR}" />
      <_XamlSourceGenMlaunchWrapperLines Include="fi" />
      <_XamlSourceGenMlaunchWrapperLines Condition="'$(_XamlSourceGenHasDotNetWatchProxy)' == 'true'" Include="if [[ -n &quot;${DOTNET_WATCH_HOTRELOAD_NAMEDPIPE_NAME:-}&quot; ]]" />
      <_XamlSourceGenMlaunchWrapperLines Condition="'$(_XamlSourceGenHasDotNetWatchProxy)' == 'true'" Include="then export SIMCTL_CHILD_AXSG_DOTNET_WATCH_PROXY_ACTIVE=true" />
      <_XamlSourceGenMlaunchWrapperLines Condition="'$(_XamlSourceGenHasDotNetWatchProxy)' == 'true'" Include="if [[ -n &quot;${AXSG_HOTRELOAD_TRACE:-}&quot; ]]" />
      <_XamlSourceGenMlaunchWrapperLines Condition="'$(_XamlSourceGenHasDotNetWatchProxy)' == 'true'" Include="then export AXSG_DOTNET_WATCH_PROXY_TRACE=1" />
      <_XamlSourceGenMlaunchWrapperLines Condition="'$(_XamlSourceGenHasDotNetWatchProxy)' == 'true'" Include="export AXSG_DOTNET_WATCH_PROXY_LOG=${TMPDIR:-/tmp}/axsg-dotnet-watch-proxy-${DOTNET_WATCH_HOTRELOAD_NAMEDPIPE_NAME}.log" />
      <_XamlSourceGenMlaunchWrapperLines Condition="'$(_XamlSourceGenHasDotNetWatchProxy)' == 'true'" Include="DOTNET_STARTUP_HOOKS= DOTNET_MODIFIABLE_ASSEMBLIES= DOTNET_WATCH=0 HOTRELOAD_DELTA_CLIENT_LOG_MESSAGES= dotnet exec &quot;$(AvaloniaSourceGenIosDotNetWatchProxyPath)&quot; --pipe-name &quot;${DOTNET_WATCH_HOTRELOAD_NAMEDPIPE_NAME}&quot; &gt;&gt;&quot;${AXSG_DOTNET_WATCH_PROXY_LOG}&quot; 2&gt;&amp;1 &amp; AXSG_PROXY_PID=$!; AXSG_PROXY_ACTIVE=true" />
      <_XamlSourceGenMlaunchWrapperLines Condition="'$(_XamlSourceGenHasDotNetWatchProxy)' == 'true'" Include="echo &quot;[AXSG.HotReload.iOS] dotnet-watch proxy started: pipe=${DOTNET_WATCH_HOTRELOAD_NAMEDPIPE_NAME} log=${AXSG_DOTNET_WATCH_PROXY_LOG}&quot; &gt;&amp;2" />
      <_XamlSourceGenMlaunchWrapperLines Condition="'$(_XamlSourceGenHasDotNetWatchProxy)' == 'true'" Include="else DOTNET_STARTUP_HOOKS= DOTNET_MODIFIABLE_ASSEMBLIES= DOTNET_WATCH=0 HOTRELOAD_DELTA_CLIENT_LOG_MESSAGES= dotnet exec &quot;$(AvaloniaSourceGenIosDotNetWatchProxyPath)&quot; --pipe-name &quot;${DOTNET_WATCH_HOTRELOAD_NAMEDPIPE_NAME}&quot; &gt;/dev/null 2&gt;&amp;1 &amp; AXSG_PROXY_PID=$!; AXSG_PROXY_ACTIVE=true" />
      <_XamlSourceGenMlaunchWrapperLines Condition="'$(_XamlSourceGenHasDotNetWatchProxy)' == 'true'" Include="fi" />
      <_XamlSourceGenMlaunchWrapperLines Condition="'$(_XamlSourceGenHasDotNetWatchProxy)' == 'true'" Include="fi" />
      <_XamlSourceGenMlaunchWrapperLines Include="if [[ -n &quot;${AXSG_HOTRELOAD_TRACE:-}&quot; ]]; then echo &quot;[AXSG.HotReload.iOS] mlaunch args: $*&quot; &gt;&amp;2; fi" />
      <_XamlSourceGenMlaunchWrapperLines Condition="'$(_XamlSourceGenResolvedRemoteEndpoint)' != ''" Include="xcrun simctl spawn booted launchctl setenv AXSG_HOTRELOAD_REMOTE_ENDPOINT &quot;$(_XamlSourceGenResolvedRemoteEndpoint)&quot; &gt;/dev/null 2&gt;&amp;1 || true" />
      <_XamlSourceGenMlaunchWrapperLines Condition="'$(_XamlSourceGenResolvedRemoteEndpoint)' == ''" Include="xcrun simctl spawn booted launchctl unsetenv AXSG_HOTRELOAD_REMOTE_ENDPOINT &gt;/dev/null 2&gt;&amp;1 || true" />
      <_XamlSourceGenMlaunchWrapperLines Include="export SIMCTL_CHILD_AXSG_IOS_HOTRELOAD_ENABLED=true" />
      <_XamlSourceGenMlaunchWrapperLines Include="export SIMCTL_CHILD_AXSG_HOTRELOAD_TRANSPORT_MODE=$(AvaloniaSourceGenIosHotReloadTransportMode)" />
      <_XamlSourceGenMlaunchWrapperLines Include="export SIMCTL_CHILD_AXSG_HOTRELOAD_HANDSHAKE_TIMEOUT_MS=$(AvaloniaSourceGenIosHotReloadHandshakeTimeoutMs)" />
      <_XamlSourceGenMlaunchWrapperLines Condition="'$(_XamlSourceGenResolvedRemoteEndpoint)' != ''" Include="export SIMCTL_CHILD_AXSG_HOTRELOAD_REMOTE_ENDPOINT=$(_XamlSourceGenResolvedRemoteEndpoint)" />
      <_XamlSourceGenMlaunchWrapperLines Condition="'$(_XamlSourceGenResolvedRemoteEndpoint)' == ''" Include="export SIMCTL_CHILD_AXSG_HOTRELOAD_REMOTE_ENDPOINT=__AXSG_NO_ENDPOINT__" />
      <_XamlSourceGenMlaunchWrapperLines Condition="'$(_XamlSourceGenResolvedRemoteEndpoint)' != ''" Include="export SIMCTL_CHILD_AXSG_HOTRELOAD_REMOTE_ENDPOINT_EXPLICIT=true" />
      <_XamlSourceGenMlaunchWrapperLines Condition="'$(_XamlSourceGenResolvedRemoteEndpoint)' == ''" Include="export SIMCTL_CHILD_AXSG_HOTRELOAD_REMOTE_ENDPOINT_EXPLICIT=false" />
      <_XamlSourceGenMlaunchWrapperLines Condition="'$(_XamlSourceGenResolvedRemoteEndpoint)' != ''" Include="AXSG_MLAUNCH_ENV_ARGS+=(--setenv=AXSG_HOTRELOAD_REMOTE_ENDPOINT=$(_XamlSourceGenEscapedAxsgRemoteEndpoint))" />
      <_XamlSourceGenMlaunchWrapperLines Condition="'$(_XamlSourceGenResolvedRemoteEndpoint)' == ''" Include="AXSG_MLAUNCH_ENV_ARGS+=(--setenv=AXSG_HOTRELOAD_REMOTE_ENDPOINT=__AXSG_NO_ENDPOINT__)" />
      <_XamlSourceGenMlaunchWrapperLines Condition="'$(_XamlSourceGenResolvedRemoteEndpoint)' != ''" Include="AXSG_MLAUNCH_ENV_ARGS+=(--setenv=AXSG_HOTRELOAD_REMOTE_ENDPOINT_EXPLICIT=true)" />
      <_XamlSourceGenMlaunchWrapperLines Condition="'$(_XamlSourceGenResolvedRemoteEndpoint)' == ''" Include="AXSG_MLAUNCH_ENV_ARGS+=(--setenv=AXSG_HOTRELOAD_REMOTE_ENDPOINT_EXPLICIT=false)" />
      <_XamlSourceGenMlaunchWrapperLines Include="if [[ -n &quot;${DOTNET_WATCH_HOTRELOAD_NAMEDPIPE_NAME:-}&quot; ]]; then AXSG_MLAUNCH_ENV_ARGS+=(--setenv=DOTNET_WATCH_HOTRELOAD_NAMEDPIPE_NAME=${DOTNET_WATCH_HOTRELOAD_NAMEDPIPE_NAME}); fi" />
      <_XamlSourceGenMlaunchWrapperLines Include="if [[ -n &quot;${DOTNET_HOTRELOAD_NAMEDPIPE_NAME:-}&quot; ]]; then AXSG_MLAUNCH_ENV_ARGS+=(--setenv=DOTNET_HOTRELOAD_NAMEDPIPE_NAME=${DOTNET_HOTRELOAD_NAMEDPIPE_NAME}); fi" />
      <_XamlSourceGenMlaunchWrapperLines Include="if [[ -n &quot;${TMPDIR:-}&quot; ]]; then AXSG_MLAUNCH_ENV_ARGS+=(--setenv=AXSG_DOTNET_WATCH_PIPE_DIRECTORY=${TMPDIR}); fi" />
      <_XamlSourceGenMlaunchWrapperLines Condition="'$(AvaloniaSourceGenIosHotReloadForwardModifiableAssemblies)' == 'true'" Include="if [[ -n &quot;${DOTNET_MODIFIABLE_ASSEMBLIES:-}&quot; ]]; then AXSG_MLAUNCH_ENV_ARGS+=(--setenv=DOTNET_MODIFIABLE_ASSEMBLIES=${DOTNET_MODIFIABLE_ASSEMBLIES}); fi" />
      <_XamlSourceGenMlaunchWrapperLines Condition="'$(AvaloniaSourceGenIosHotReloadForwardStartupHooks)' == 'true'" Include="if [[ -n &quot;${DOTNET_STARTUP_HOOKS:-}&quot; ]]; then AXSG_MLAUNCH_ENV_ARGS+=(--setenv=DOTNET_STARTUP_HOOKS=${DOTNET_STARTUP_HOOKS}); fi" />
      <_XamlSourceGenMlaunchWrapperLines Include="if [[ &quot;${AXSG_PROXY_ACTIVE}&quot; == &quot;true&quot; &amp;&amp; -n &quot;${AXSG_PROXY_PID}&quot; ]]; then trap 'kill ${AXSG_PROXY_PID} &gt;/dev/null 2&gt;&amp;1 || true' EXIT; fi" />
      <_XamlSourceGenMlaunchWrapperLines Include="if [[ &quot;${AXSG_PROXY_ACTIVE}&quot; == &quot;true&quot; &amp;&amp; -n &quot;${AXSG_PROXY_PID}&quot; ]]; then &quot;${REAL_MLAUNCH}&quot; &quot;${AXSG_MLAUNCH_ENV_ARGS[@]}&quot; &quot;$@&quot;; AXSG_MLAUNCH_EXIT=$?; if [[ ${AXSG_MLAUNCH_EXIT} -ne 0 ]]; then kill ${AXSG_PROXY_PID} &gt;/dev/null 2&gt;&amp;1 || true; wait ${AXSG_PROXY_PID} || true; exit ${AXSG_MLAUNCH_EXIT}; fi; if [[ -n &quot;${AXSG_HOTRELOAD_TRACE:-}&quot; ]]; then echo &quot;[AXSG.HotReload.iOS] mlaunch exited, keeping watch session alive via proxy pid=${AXSG_PROXY_PID}.&quot; &gt;&amp;2; fi; wait ${AXSG_PROXY_PID} || true; exit ${AXSG_MLAUNCH_EXIT}; fi" />
      <_XamlSourceGenMlaunchWrapperLines Include="exec &quot;${REAL_MLAUNCH}&quot; &quot;${AXSG_MLAUNCH_ENV_ARGS[@]}&quot; &quot;$@&quot;" />
    </ItemGroup>

    <WriteLinesToFile Condition="'$(_XamlSourceGenUseMlaunchWrapper)' == 'true'"
                      File="$(_XamlSourceGenMlaunchWrapperPath)"
                      Lines="@(_XamlSourceGenMlaunchWrapperLines)"
                      Overwrite="true"
                      WriteOnlyWhenDifferent="true" />
    <Exec Condition="'$(_XamlSourceGenUseMlaunchWrapper)' == 'true'"
          Command="chmod +x &quot;$(_XamlSourceGenMlaunchWrapperPath)&quot;" />

    <PropertyGroup Condition="'$(_XamlSourceGenUseMlaunchWrapper)' == 'true'">
      <MlaunchPath>$(_XamlSourceGenMlaunchWrapperPath)</MlaunchPath>
      <_MlaunchPath>$(_XamlSourceGenMlaunchWrapperPath)</_MlaunchPath>
    </PropertyGroup>
    <Message Importance="Low"
             Condition="'$(AvaloniaSourceGenIosHotReloadStartupBannerEnabled)' == 'true'"
             Text="[AXSG.HotReload.iOS] Mlaunch wrapper: enabled=$(_XamlSourceGenUseMlaunchWrapper), original=$(_XamlSourceGenOriginalMlaunchPath), wrapper=$(_XamlSourceGenMlaunchWrapperPath)." />
    <Message Importance="Low"
             Condition="'$(AvaloniaSourceGenIosHotReloadStartupBannerEnabled)' == 'true'"
             Text="[AXSG.HotReload.iOS] dotnet-watch proxy: configuredPath=$(AvaloniaSourceGenIosDotNetWatchProxyPath), exists=$(_XamlSourceGenHasDotNetWatchProxy)." />
  </Target>

  <Target Name="XamlToCSharpGenerator_BuildIosDotNetWatchProxy"
          BeforeTargets="XamlToCSharpGenerator_PrepareIosMlaunchWrapper"
          Condition="'$(_XamlSourceGenEnableIosDotNetWatchHotReload)' == 'true' and '$(AvaloniaSourceGenIosDotNetWatchProxyProjectPath)' != '' and Exists('$(AvaloniaSourceGenIosDotNetWatchProxyProjectPath)')">
    <MSBuild Projects="$(AvaloniaSourceGenIosDotNetWatchProxyProjectPath)"
             Targets="Build"
             Properties="Configuration=$(Configuration);DesignTimeBuild=false;BuildingProject=false"
             BuildInParallel="false"
             StopOnFirstFailure="true" />
  </Target>

  <Target Name="XamlToCSharpGenerator_ConfigureIosDotNetWatchHotReload"
          BeforeTargets="_ComputeMlaunchRunArguments;ComputeMlaunchRunArguments;_PrepareRunMobile;ComputeRunArguments"
          DependsOnTargets="_DetectSdkLocations"
          Condition="'$(_XamlSourceGenEnableIosDotNetWatchHotReload)' == 'true'">
    <PropertyGroup>
      <!-- Resolve simulator/device mode after iOS SDK targets have evaluated runtime/device state. -->
      <_XamlSourceGenIsIosSimulator>false</_XamlSourceGenIsIosSimulator>
      <_XamlSourceGenIsIosSimulator Condition="'$(RuntimeIdentifier)' != '' and $([System.String]::Copy('$(RuntimeIdentifier)').Contains('iossimulator'))">true</_XamlSourceGenIsIosSimulator>
      <_XamlSourceGenIsIosSimulator Condition="'$(_XamlSourceGenIsIosSimulator)' != 'true' and '$(_SdkIsSimulator)' == 'True'">true</_XamlSourceGenIsIosSimulator>
      <_XamlSourceGenIsIosSimulator Condition="'$(_XamlSourceGenIsIosSimulator)' != 'true' and ('$(Platform)' == 'iPhoneSimulator' or '$(PlatformTarget)' == 'iPhoneSimulator')">true</_XamlSourceGenIsIosSimulator>

      <_XamlSourceGenDotNetStartupHooksValue>$(DOTNET_STARTUP_HOOKS)</_XamlSourceGenDotNetStartupHooksValue>
      <_XamlSourceGenDotNetStartupHooksValue Condition="'$(_XamlSourceGenDotNetStartupHooksValue)' == ''">$([System.Environment]::GetEnvironmentVariable('DOTNET_STARTUP_HOOKS'))</_XamlSourceGenDotNetStartupHooksValue>
      <_XamlSourceGenDotNetModifiableAssembliesValue>$(DOTNET_MODIFIABLE_ASSEMBLIES)</_XamlSourceGenDotNetModifiableAssembliesValue>
      <_XamlSourceGenDotNetModifiableAssembliesValue Condition="'$(_XamlSourceGenDotNetModifiableAssembliesValue)' == ''">$([System.Environment]::GetEnvironmentVariable('DOTNET_MODIFIABLE_ASSEMBLIES'))</_XamlSourceGenDotNetModifiableAssembliesValue>
      <_XamlSourceGenDotNetWatchNamedPipeValue>$(DOTNET_WATCH_HOTRELOAD_NAMEDPIPE_NAME)</_XamlSourceGenDotNetWatchNamedPipeValue>
      <_XamlSourceGenDotNetWatchNamedPipeValue Condition="'$(_XamlSourceGenDotNetWatchNamedPipeValue)' == ''">$([System.Environment]::GetEnvironmentVariable('DOTNET_WATCH_HOTRELOAD_NAMEDPIPE_NAME'))</_XamlSourceGenDotNetWatchNamedPipeValue>
      <_XamlSourceGenDotNetHotReloadNamedPipeValue>$(DOTNET_HOTRELOAD_NAMEDPIPE_NAME)</_XamlSourceGenDotNetHotReloadNamedPipeValue>
      <_XamlSourceGenDotNetHotReloadNamedPipeValue Condition="'$(_XamlSourceGenDotNetHotReloadNamedPipeValue)' == ''">$([System.Environment]::GetEnvironmentVariable('DOTNET_HOTRELOAD_NAMEDPIPE_NAME'))</_XamlSourceGenDotNetHotReloadNamedPipeValue>
      <_XamlSourceGenAxsgTraceValue>$(AXSG_HOTRELOAD_TRACE)</_XamlSourceGenAxsgTraceValue>
      <_XamlSourceGenAxsgTraceValue Condition="'$(_XamlSourceGenAxsgTraceValue)' == ''">$([System.Environment]::GetEnvironmentVariable('AXSG_HOTRELOAD_TRACE'))</_XamlSourceGenAxsgTraceValue>

      <_XamlSourceGenEscapedDotNetStartupHooks>$([System.String]::Copy('$(_XamlSourceGenDotNetStartupHooksValue)').Replace(';', '%3B'))</_XamlSourceGenEscapedDotNetStartupHooks>
      <_XamlSourceGenEscapedDotNetModifiableAssemblies>$([System.String]::Copy('$(_XamlSourceGenDotNetModifiableAssembliesValue)').Replace(';', '%3B'))</_XamlSourceGenEscapedDotNetModifiableAssemblies>
      <_XamlSourceGenEscapedDotNetWatchNamedPipe>$([System.String]::Copy('$(_XamlSourceGenDotNetWatchNamedPipeValue)').Replace(';', '%3B'))</_XamlSourceGenEscapedDotNetWatchNamedPipe>
      <_XamlSourceGenEscapedDotNetHotReloadNamedPipe>$([System.String]::Copy('$(_XamlSourceGenDotNetHotReloadNamedPipeValue)').Replace(';', '%3B'))</_XamlSourceGenEscapedDotNetHotReloadNamedPipe>
      <_XamlSourceGenEscapedAxsgTrace>$([System.String]::Copy('$(_XamlSourceGenAxsgTraceValue)').Replace(';', '%3B'))</_XamlSourceGenEscapedAxsgTrace>
      <_XamlSourceGenEscapedAxsgTransportMode>$([System.String]::Copy('$(AvaloniaSourceGenIosHotReloadTransportMode)').Replace(';', '%3B'))</_XamlSourceGenEscapedAxsgTransportMode>
      <_XamlSourceGenEscapedAxsgHandshakeTimeoutMs>$([System.String]::Copy('$(AvaloniaSourceGenIosHotReloadHandshakeTimeoutMs)').Replace(';', '%3B'))</_XamlSourceGenEscapedAxsgHandshakeTimeoutMs>

      <_XamlSourceGenResolvedRemoteEndpoint>$(AvaloniaSourceGenHotReloadRemoteEndpoint)</_XamlSourceGenResolvedRemoteEndpoint>
      <_XamlSourceGenResolvedRemoteEndpoint Condition="'$(_XamlSourceGenResolvedRemoteEndpoint)' == '' and '$(_XamlSourceGenIsIosSimulator)' == 'true' and '$(AvaloniaSourceGenHotReloadRemoteAutoSimulatorEndpointEnabled)' == 'true'">tcp://127.0.0.1:$(AvaloniaSourceGenHotReloadRemotePort)</_XamlSourceGenResolvedRemoteEndpoint>
      <_XamlSourceGenRemoteEndpointWasAutoSelected>false</_XamlSourceGenRemoteEndpointWasAutoSelected>
      <_XamlSourceGenRemoteEndpointWasAutoSelected Condition="'$(AvaloniaSourceGenHotReloadRemoteEndpoint)' == '' and '$(_XamlSourceGenResolvedRemoteEndpoint)' != '' and '$(_XamlSourceGenIsIosSimulator)' == 'true' and '$(AvaloniaSourceGenHotReloadRemoteAutoSimulatorEndpointEnabled)' == 'true'">true</_XamlSourceGenRemoteEndpointWasAutoSelected>
      <_XamlSourceGenRequiresExplicitDeviceEndpoint>false</_XamlSourceGenRequiresExplicitDeviceEndpoint>
      <_XamlSourceGenRequiresExplicitDeviceEndpoint Condition="'$(_XamlSourceGenIsIosSimulator)' != 'true' and '$(AvaloniaSourceGenHotReloadRemoteRequireExplicitDeviceEndpoint)' == 'true' and '$(AvaloniaSourceGenIosHotReloadTransportMode)' != 'MetadataOnly' and '$(_XamlSourceGenResolvedRemoteEndpoint)' == ''">true</_XamlSourceGenRequiresExplicitDeviceEndpoint>
      <_XamlSourceGenEscapedAxsgRemoteEndpoint>$([System.String]::Copy('$(_XamlSourceGenResolvedRemoteEndpoint)').Replace(';', '%3B'))</_XamlSourceGenEscapedAxsgRemoteEndpoint>

      <_XamlSourceGenHasDotNetStartupHooksVar>false</_XamlSourceGenHasDotNetStartupHooksVar>
      <_XamlSourceGenHasDotNetStartupHooksVar Condition="'$(AvaloniaSourceGenIosHotReloadForwardStartupHooks)' == 'true' and '$(_XamlSourceGenDotNetStartupHooksValue)' != ''">true</_XamlSourceGenHasDotNetStartupHooksVar>
      <_XamlSourceGenStartupHooksSuppressed>false</_XamlSourceGenStartupHooksSuppressed>
      <_XamlSourceGenStartupHooksSuppressed Condition="'$(_XamlSourceGenDotNetStartupHooksValue)' != '' and '$(AvaloniaSourceGenIosHotReloadForwardStartupHooks)' != 'true'">true</_XamlSourceGenStartupHooksSuppressed>
      <_XamlSourceGenHasDotNetWatchNamedPipeVar>false</_XamlSourceGenHasDotNetWatchNamedPipeVar>
      <_XamlSourceGenHasDotNetWatchNamedPipeVar Condition="'$(_XamlSourceGenDotNetWatchNamedPipeValue)' != '' or '$(_XamlSourceGenDotNetHotReloadNamedPipeValue)' != ''">true</_XamlSourceGenHasDotNetWatchNamedPipeVar>

      <_XamlSourceGenMlaunchSetEnvArguments></_XamlSourceGenMlaunchSetEnvArguments>
      <_XamlSourceGenMlaunchSetEnvArguments Condition="'$(AvaloniaSourceGenIosHotReloadForwardWatchEnvironment)' == 'true' and '$(_XamlSourceGenIsIosSimulator)' != 'true' and '$(AvaloniaSourceGenIosHotReloadForwardStartupHooks)' == 'true' and '$(_XamlSourceGenDotNetStartupHooksValue)' != ''">$(_XamlSourceGenMlaunchSetEnvArguments);--setenv=DOTNET_STARTUP_HOOKS=$(_XamlSourceGenEscapedDotNetStartupHooks)</_XamlSourceGenMlaunchSetEnvArguments>
      <_XamlSourceGenMlaunchSetEnvArguments Condition="'$(AvaloniaSourceGenIosHotReloadForwardWatchEnvironment)' == 'true' and '$(_XamlSourceGenIsIosSimulator)' != 'true' and '$(AvaloniaSourceGenIosHotReloadForwardModifiableAssemblies)' == 'true' and '$(_XamlSourceGenDotNetModifiableAssembliesValue)' != ''">$(_XamlSourceGenMlaunchSetEnvArguments);--setenv=DOTNET_MODIFIABLE_ASSEMBLIES=$(_XamlSourceGenEscapedDotNetModifiableAssemblies)</_XamlSourceGenMlaunchSetEnvArguments>
      <_XamlSourceGenMlaunchSetEnvArguments Condition="'$(AvaloniaSourceGenIosHotReloadForwardWatchEnvironment)' == 'true' and '$(_XamlSourceGenIsIosSimulator)' != 'true' and '$(_XamlSourceGenDotNetWatchNamedPipeValue)' != ''">$(_XamlSourceGenMlaunchSetEnvArguments);--setenv=DOTNET_WATCH_HOTRELOAD_NAMEDPIPE_NAME=$(_XamlSourceGenEscapedDotNetWatchNamedPipe)</_XamlSourceGenMlaunchSetEnvArguments>
      <_XamlSourceGenMlaunchSetEnvArguments Condition="'$(AvaloniaSourceGenIosHotReloadForwardWatchEnvironment)' == 'true' and '$(_XamlSourceGenIsIosSimulator)' != 'true' and '$(_XamlSourceGenDotNetHotReloadNamedPipeValue)' != ''">$(_XamlSourceGenMlaunchSetEnvArguments);--setenv=DOTNET_HOTRELOAD_NAMEDPIPE_NAME=$(_XamlSourceGenEscapedDotNetHotReloadNamedPipe)</_XamlSourceGenMlaunchSetEnvArguments>
      <_XamlSourceGenMlaunchSetEnvArguments Condition="'$(AvaloniaSourceGenIosHotReloadForwardWatchEnvironment)' == 'true' and '$(_XamlSourceGenIsIosSimulator)' != 'true' and '$(_XamlSourceGenAxsgTraceValue)' != ''">$(_XamlSourceGenMlaunchSetEnvArguments);--setenv=AXSG_HOTRELOAD_TRACE=$(_XamlSourceGenEscapedAxsgTrace)</_XamlSourceGenMlaunchSetEnvArguments>
      <_XamlSourceGenMlaunchSetEnvArguments Condition="'$(AvaloniaSourceGenIosHotReloadForwardWatchEnvironment)' == 'true' and '$(_XamlSourceGenIsIosSimulator)' != 'true'">$(_XamlSourceGenMlaunchSetEnvArguments);--setenv=AXSG_HOTRELOAD_TRANSPORT_MODE=$(_XamlSourceGenEscapedAxsgTransportMode);--setenv=AXSG_HOTRELOAD_HANDSHAKE_TIMEOUT_MS=$(_XamlSourceGenEscapedAxsgHandshakeTimeoutMs);--setenv=AXSG_IOS_HOTRELOAD_ENABLED=true</_XamlSourceGenMlaunchSetEnvArguments>
      <_XamlSourceGenMlaunchSetEnvArguments Condition="'$(AvaloniaSourceGenIosHotReloadForwardWatchEnvironment)' == 'true' and '$(_XamlSourceGenIsIosSimulator)' != 'true' and '$(_XamlSourceGenResolvedRemoteEndpoint)' != ''">$(_XamlSourceGenMlaunchSetEnvArguments);--setenv=AXSG_HOTRELOAD_REMOTE_ENDPOINT=$(_XamlSourceGenEscapedAxsgRemoteEndpoint)</_XamlSourceGenMlaunchSetEnvArguments>
      <_XamlSourceGenMlaunchSetEnvArguments Condition="'$(AvaloniaSourceGenIosHotReloadForwardWatchEnvironment)' == 'true' and '$(_XamlSourceGenIsIosSimulator)' != 'true' and '$(_XamlSourceGenResolvedRemoteEndpoint)' == ''">$(_XamlSourceGenMlaunchSetEnvArguments);--setenv=AXSG_HOTRELOAD_REMOTE_ENDPOINT=__AXSG_NO_ENDPOINT__</_XamlSourceGenMlaunchSetEnvArguments>
      <_XamlSourceGenMlaunchSetEnvArguments Condition="'$(AvaloniaSourceGenIosHotReloadForwardWatchEnvironment)' == 'true' and '$(_XamlSourceGenIsIosSimulator)' != 'true' and '$(_XamlSourceGenResolvedRemoteEndpoint)' != ''">$(_XamlSourceGenMlaunchSetEnvArguments);--setenv=AXSG_HOTRELOAD_REMOTE_ENDPOINT_EXPLICIT=true</_XamlSourceGenMlaunchSetEnvArguments>
      <_XamlSourceGenMlaunchSetEnvArguments Condition="'$(AvaloniaSourceGenIosHotReloadForwardWatchEnvironment)' == 'true' and '$(_XamlSourceGenIsIosSimulator)' != 'true' and '$(_XamlSourceGenResolvedRemoteEndpoint)' == ''">$(_XamlSourceGenMlaunchSetEnvArguments);--setenv=AXSG_HOTRELOAD_REMOTE_ENDPOINT_EXPLICIT=false</_XamlSourceGenMlaunchSetEnvArguments>

      <_XamlSourceGenHasSetEnvArgs>false</_XamlSourceGenHasSetEnvArgs>
      <_XamlSourceGenHasSetEnvArgs Condition="'$(_XamlSourceGenMlaunchSetEnvArguments)' != ''">true</_XamlSourceGenHasSetEnvArgs>
      <MlaunchAdditionalArgumentsProperty Condition="'$(_XamlSourceGenHasSetEnvArgs)' == 'true' and $([System.String]::Copy('$(MlaunchAdditionalArgumentsProperty)').Contains('AXSG_IOS_HOTRELOAD_ENABLED')) != 'True'">$(MlaunchAdditionalArgumentsProperty)$(_XamlSourceGenMlaunchSetEnvArguments)</MlaunchAdditionalArgumentsProperty>
    </PropertyGroup>
    <Message Importance="Low"
             Condition="'$(AvaloniaSourceGenIosHotReloadStartupBannerEnabled)' == 'true'"
             Text="[AXSG.HotReload.iOS] Launch tuning: sdkSimulator=$(_SdkIsSimulator), simulator=$(_XamlSourceGenIsIosSimulator), waitForExit=$(_MlaunchWaitForExit), captureOutput=$(_MlaunchCaptureOutput)." />
    <Warning Condition="'$(_XamlSourceGenRequiresExplicitDeviceEndpoint)' == 'true'"
             Text="[AXSG.HotReload.iOS] Physical-device remote fallback requires a reachable host endpoint. Set AvaloniaSourceGenHotReloadRemoteEndpoint (or AXSG_HOTRELOAD_REMOTE_ENDPOINT), for example tcp://192.168.1.10:$(AvaloniaSourceGenHotReloadRemotePort)." />
    <Message Importance="High"
             Condition="'$(AvaloniaSourceGenIosHotReloadStartupBannerEnabled)' == 'true'"
             Text="[AXSG.HotReload.iOS] Enabled for $(MSBuildProjectName) (TFM=$(TargetFramework), watchBuild=$(DotNetWatchBuild), watchEnv=$(DOTNET_WATCH), sdkSimulator=$(_SdkIsSimulator), simulator=$(_XamlSourceGenIsIosSimulator), interpreter=$(AvaloniaSourceGenIosHotReloadUseInterpreter), forwardEnv=$(AvaloniaSourceGenIosHotReloadForwardWatchEnvironment), forwardStartupHooks=$(AvaloniaSourceGenIosHotReloadForwardStartupHooks), forwardModifiableAssemblies=$(AvaloniaSourceGenIosHotReloadForwardModifiableAssemblies), startupHookSupport=$(StartupHookSupport), transport=$(AvaloniaSourceGenIosHotReloadTransportMode), timeoutMs=$(AvaloniaSourceGenIosHotReloadHandshakeTimeoutMs), remoteEndpoint=$(_XamlSourceGenResolvedRemoteEndpoint), remoteEndpointAuto=$(_XamlSourceGenRemoteEndpointWasAutoSelected), requiresExplicitDeviceEndpoint=$(_XamlSourceGenRequiresExplicitDeviceEndpoint), startupHooksVar=$(_XamlSourceGenHasDotNetStartupHooksVar), startupHooksSuppressed=$(_XamlSourceGenStartupHooksSuppressed), namedPipeVar=$(_XamlSourceGenHasDotNetWatchNamedPipeVar), setenvArgs=$(_XamlSourceGenHasSetEnvArgs), waitForExit=$(_MlaunchWaitForExit), captureOutput=$(_MlaunchCaptureOutput))." />
  </Target>

  <PropertyGroup Condition="'$(XamlSourceGenEnabled)' == 'true'">
    <EnableAvaloniaXamlCompilation>false</EnableAvaloniaXamlCompilation>
    <AvaloniaNameGeneratorIsEnabled>false</AvaloniaNameGeneratorIsEnabled>
    <DefineConstants>$(DefineConstants);AXAML_SOURCEGEN_BACKEND</DefineConstants>
  </PropertyGroup>

  <ItemGroup Condition="'$(XamlSourceGenEnabled)' == 'true' and '$(XamlSourceGenTransformRules)' != ''">
    <XamlSourceGenTransformRule Include="$(XamlSourceGenTransformRules)" />
  </ItemGroup>

  <!-- Keep AXAML visible to Roslyn/project-system even when certain design-time IDE pipelines don't execute _InjectAdditionalFiles. -->
  <ItemGroup Condition="'$(XamlSourceGenEnabled)' == 'true'">
    <_XamlToCSharpGeneratorXamlProjected Include="@($(XamlSourceGenInputItemGroup))">
      <NormalizedFullPath>%(FullPath)</NormalizedFullPath>
    </_XamlToCSharpGeneratorXamlProjected>

    <_XamlToCSharpGeneratorTransformRuleProjected Include="@(XamlSourceGenTransformRule);@(AvaloniaSourceGenTransformRule)">
      <NormalizedFullPath>%(FullPath)</NormalizedFullPath>
    </_XamlToCSharpGeneratorTransformRuleProjected>
    <Watch Include="@(_XamlToCSharpGeneratorXamlProjected->'%(NormalizedFullPath)'->Distinct())"
           Condition="'$(DotNetWatchBuild)' != 'true' or '$(_XamlSourceGenEnableDotNetWatchXamlBuildTriggers)' == 'true'">
      <XamlToCSharpGenerator>true</XamlToCSharpGenerator>
    </Watch>
    <Watch Include="@(_XamlToCSharpGeneratorTransformRuleProjected->'%(NormalizedFullPath)'->Distinct())">
      <XamlToCSharpGenerator>true</XamlToCSharpGenerator>
    </Watch>

    <CustomAdditionalCompileInputs Include="@(_XamlToCSharpGeneratorXamlProjected)"
                                   Condition="'$(_XamlSourceGenEnableDotNetWatchXamlCompileInputs)' == 'true'">
      <XamlToCSharpGenerator>true</XamlToCSharpGenerator>
    </CustomAdditionalCompileInputs>
    <UpToDateCheckInput Include="@(_XamlToCSharpGeneratorXamlProjected)"
                        Condition="'$(_XamlSourceGenEnableDotNetWatchXamlCompileInputs)' == 'true'">
      <XamlToCSharpGenerator>true</XamlToCSharpGenerator>
    </UpToDateCheckInput>
  </ItemGroup>

  <Target Name="XamlToCSharpGenerator_PrepareCoreCompileInputs"
          BeforeTargets="CoreCompile"
          Condition="'$(XamlSourceGenEnabled)' == 'true'">
    <RemoveDuplicates Inputs="@(_XamlToCSharpGeneratorXamlProjected)">
      <Output TaskParameter="Filtered" ItemName="_XamlToCSharpGeneratorXamlCompileInputDistinct" />
    </RemoveDuplicates>

    <ItemGroup>
      <CustomAdditionalCompileInputs Remove="@(CustomAdditionalCompileInputs)" Condition="'%(CustomAdditionalCompileInputs.XamlToCSharpGenerator)' == 'true'" />
      <CustomAdditionalCompileInputs Include="@(_XamlToCSharpGeneratorXamlCompileInputDistinct)"
                                     Condition="'$(_XamlSourceGenEnableDotNetWatchXamlCompileInputs)' == 'true'">
        <XamlToCSharpGenerator>true</XamlToCSharpGenerator>
      </CustomAdditionalCompileInputs>
    </ItemGroup>
  </Target>

  <Target Name="XamlToCSharpGenerator_CollectUpToDateCheckInputDesignTime"
          BeforeTargets="CollectUpToDateCheckInputDesignTime"
          Condition="'$(XamlSourceGenEnabled)' == 'true'">
    <RemoveDuplicates Inputs="@(_XamlToCSharpGeneratorXamlProjected)">
      <Output TaskParameter="Filtered" ItemName="_XamlToCSharpGeneratorXamlUpToDateDistinct" />
    </RemoveDuplicates>

    <ItemGroup>
      <UpToDateCheckInput Remove="@(UpToDateCheckInput)" Condition="'%(UpToDateCheckInput.XamlToCSharpGenerator)' == 'true'" />
      <UpToDateCheckInput Include="@(_XamlToCSharpGeneratorXamlUpToDateDistinct)"
                          Condition="'$(_XamlSourceGenEnableDotNetWatchXamlCompileInputs)' == 'true'">
        <XamlToCSharpGenerator>true</XamlToCSharpGenerator>
      </UpToDateCheckInput>
    </ItemGroup>
  </Target>

  <Target Name="XamlToCSharpGenerator_ValidateAdditionalFilesSourceItemGroup"
          BeforeTargets="XamlToCSharpGenerator_InjectAdditionalFiles"
          Condition="'$(_XamlSourceGenAdditionalFilesSourceItemGroupGuarded)' == 'true'">
    <Warning Text="[AXSG.Build] XamlSourceGenAdditionalFilesSourceItemGroup='$(_XamlSourceGenRequestedAdditionalFilesSourceItemGroup)' is not supported for Avalonia consumers. AXSG always tags projected AdditionalFiles as '$(_XamlSourceGenSupportedAdditionalFilesSourceItemGroup)'. Keep your custom project item group in XamlSourceGenInputItemGroup and remove the AdditionalFiles override." />
  </Target>

  <Target Name="XamlToCSharpGenerator_InjectAdditionalFiles"
          AfterTargets="_InjectAdditionalFiles"
          BeforeTargets="GenerateMSBuildEditorConfigFileShouldRun"
          Condition="'$(XamlSourceGenEnabled)' == 'true'">
    <ItemGroup>
      <!-- Normalize all configured XAML input entries into AdditionalFiles exactly once.
           This prevents duplicate AdditionalFiles under watch/re-evaluation flows. -->
      <_XamlToCSharpGeneratorXamlRaw Include="@(_XamlToCSharpGeneratorXamlProjected)">
        <NormalizedIdentity>%(_XamlToCSharpGeneratorXamlProjected.FullPath)</NormalizedIdentity>
        <OriginalIdentity>%(_XamlToCSharpGeneratorXamlProjected.Identity)</OriginalIdentity>
        <Link>%(_XamlToCSharpGeneratorXamlProjected.Link)</Link>
        <TargetPath>%(_XamlToCSharpGeneratorXamlProjected.TargetPath)</TargetPath>
      </_XamlToCSharpGeneratorXamlRaw>

      <_XamlToCSharpGeneratorXaml Include="@(_XamlToCSharpGeneratorXamlRaw->'%(NormalizedIdentity)')">
        <OriginalIdentity>%(_XamlToCSharpGeneratorXamlRaw.OriginalIdentity)</OriginalIdentity>
        <Link>%(_XamlToCSharpGeneratorXamlRaw.Link)</Link>
        <TargetPath>%(_XamlToCSharpGeneratorXamlRaw.TargetPath)</TargetPath>
      </_XamlToCSharpGeneratorXaml>

      <_XamlToCSharpGeneratorTransformRuleRaw Include="@(_XamlToCSharpGeneratorTransformRuleProjected)">
        <NormalizedIdentity>%(FullPath)</NormalizedIdentity>
      </_XamlToCSharpGeneratorTransformRuleRaw>

      <_XamlToCSharpGeneratorTransformRule Include="@(_XamlToCSharpGeneratorTransformRuleRaw->'%(NormalizedIdentity)')">
        <OriginalIdentity>%(_XamlToCSharpGeneratorTransformRuleRaw.Identity)</OriginalIdentity>
        <Link>%(_XamlToCSharpGeneratorTransformRuleRaw.Link)</Link>
        <TargetPath>%(_XamlToCSharpGeneratorTransformRuleRaw.TargetPath)</TargetPath>
      </_XamlToCSharpGeneratorTransformRule>
    </ItemGroup>

    <RemoveDuplicates Inputs="@(_XamlToCSharpGeneratorXaml)">
      <Output TaskParameter="Filtered" ItemName="_XamlToCSharpGeneratorXamlDistinct" />
    </RemoveDuplicates>

    <RemoveDuplicates Inputs="@(_XamlToCSharpGeneratorTransformRule)">
      <Output TaskParameter="Filtered" ItemName="_XamlToCSharpGeneratorTransformRuleDistinct" />
    </RemoveDuplicates>

    <ItemGroup>

      <!-- Drop any existing AXAML AdditionalFiles projections before re-adding deterministic entries. -->
      <AdditionalFiles Remove="@(AdditionalFiles)" Condition="'%(AdditionalFiles.SourceItemGroup)' == '$(XamlSourceGenAdditionalFilesSourceItemGroup)'" />
      <AdditionalFiles Remove="@(AdditionalFiles)"
                       Condition="'$(_XamlSourceGenAdditionalFilesSourceItemGroupGuarded)' == 'true' and '%(AdditionalFiles.SourceItemGroup)' == '$(_XamlSourceGenRequestedAdditionalFilesSourceItemGroup)'" />
      <AdditionalFiles Remove="@(_XamlToCSharpGeneratorXamlProjected)" />
      <AdditionalFiles Remove="@(_XamlToCSharpGeneratorXamlProjected->'%(FullPath)')" />
      <AdditionalFiles Remove="@(_XamlToCSharpGeneratorXaml->'%(NormalizedIdentity)')" />
      <AdditionalFiles Remove="@(_XamlToCSharpGeneratorXamlDistinct)" />
      <AdditionalFiles Remove="@(AdditionalFiles)" Condition="'%(AdditionalFiles.SourceItemGroup)' == '$(XamlSourceGenTransformRuleItemGroup)'" />
      <AdditionalFiles Remove="@(XamlSourceGenTransformRule)" />
      <AdditionalFiles Remove="@(XamlSourceGenTransformRule->'%(FullPath)')" />
      <AdditionalFiles Remove="@(AvaloniaSourceGenTransformRule)" />
      <AdditionalFiles Remove="@(AvaloniaSourceGenTransformRule->'%(FullPath)')" />
      <AdditionalFiles Remove="@(_XamlToCSharpGeneratorTransformRule->'%(NormalizedIdentity)')" />
      <AdditionalFiles Remove="@(_XamlToCSharpGeneratorTransformRuleDistinct)" />
      <AdditionalFiles Include="@(_XamlToCSharpGeneratorXamlDistinct)" SourceItemGroup="$(XamlSourceGenAdditionalFilesSourceItemGroup)">
        <Watch>false</Watch>
        <TargetPath Condition="'%(_XamlToCSharpGeneratorXamlDistinct.Link)' != ''">%(_XamlToCSharpGeneratorXamlDistinct.Link)</TargetPath>
        <TargetPath Condition="'%(_XamlToCSharpGeneratorXamlDistinct.Link)' == '' and '%(_XamlToCSharpGeneratorXamlDistinct.TargetPath)' != ''">%(_XamlToCSharpGeneratorXamlDistinct.TargetPath)</TargetPath>
        <TargetPath Condition="'%(_XamlToCSharpGeneratorXamlDistinct.Link)' == '' and '%(_XamlToCSharpGeneratorXamlDistinct.TargetPath)' == '' and '%(_XamlToCSharpGeneratorXamlDistinct.OriginalIdentity)' != ''">%(_XamlToCSharpGeneratorXamlDistinct.OriginalIdentity)</TargetPath>
        <TargetPath Condition="'%(_XamlToCSharpGeneratorXamlDistinct.Link)' == '' and '%(_XamlToCSharpGeneratorXamlDistinct.TargetPath)' == '' and '%(_XamlToCSharpGeneratorXamlDistinct.OriginalIdentity)' == ''">%(_XamlToCSharpGeneratorXamlDistinct.Identity)</TargetPath>
      </AdditionalFiles>
      <AdditionalFiles Include="@(_XamlToCSharpGeneratorTransformRuleDistinct)" SourceItemGroup="$(XamlSourceGenTransformRuleItemGroup)">
        <Watch>false</Watch>
        <TargetPath Condition="'%(_XamlToCSharpGeneratorTransformRuleDistinct.Link)' != ''">%(_XamlToCSharpGeneratorTransformRuleDistinct.Link)</TargetPath>
        <TargetPath Condition="'%(_XamlToCSharpGeneratorTransformRuleDistinct.Link)' == '' and '%(_XamlToCSharpGeneratorTransformRuleDistinct.TargetPath)' != ''">%(_XamlToCSharpGeneratorTransformRuleDistinct.TargetPath)</TargetPath>
        <TargetPath Condition="'%(_XamlToCSharpGeneratorTransformRuleDistinct.Link)' == '' and '%(_XamlToCSharpGeneratorTransformRuleDistinct.TargetPath)' == '' and '%(_XamlToCSharpGeneratorTransformRuleDistinct.OriginalIdentity)' != ''">%(_XamlToCSharpGeneratorTransformRuleDistinct.OriginalIdentity)</TargetPath>
        <TargetPath Condition="'%(_XamlToCSharpGeneratorTransformRuleDistinct.Link)' == '' and '%(_XamlToCSharpGeneratorTransformRuleDistinct.TargetPath)' == '' and '%(_XamlToCSharpGeneratorTransformRuleDistinct.OriginalIdentity)' == ''">%(_XamlToCSharpGeneratorTransformRuleDistinct.Identity)</TargetPath>
      </AdditionalFiles>

      <_XamlToCSharpGeneratorXamlWatch Include="@(_XamlToCSharpGeneratorXamlDistinct)"
                                       Condition="'$(DotNetWatchBuild)' != 'true' or '$(_XamlSourceGenEnableDotNetWatchXamlBuildTriggers)' == 'true'" />
      <_XamlToCSharpGeneratorTransformRuleWatch Include="@(_XamlToCSharpGeneratorTransformRuleDistinct)" />
      <Watch Remove="@(_XamlToCSharpGeneratorXamlWatch)" />
      <Watch Remove="@(_XamlToCSharpGeneratorTransformRuleWatch)" />
      <Watch Include="@(_XamlToCSharpGeneratorXamlWatch)">
        <XamlToCSharpGenerator>true</XamlToCSharpGenerator>
      </Watch>
      <Watch Include="@(_XamlToCSharpGeneratorTransformRuleWatch)">
        <XamlToCSharpGenerator>true</XamlToCSharpGenerator>
      </Watch>
    </ItemGroup>
  </Target>

  <Target Name="XamlToCSharpGenerator_FilterDotNetWatchItems"
          DependsOnTargets="XamlToCSharpGenerator_InjectAdditionalFiles"
          Condition="'$(XamlSourceGenEnabled)' == 'true' and '$(DotNetWatchBuild)' == 'true' and '$(AvaloniaSourceGenHotReloadEnabled)' == 'true' and '$(AvaloniaSourceGenIdeHotReloadEnabled)' == 'true' and '$(_XamlSourceGenEnableDotNetWatchXamlBuildTriggers)' != 'true'">
    <ItemGroup>
      <!-- dotnet-watch auto-adds embedded resources to its watch list; AXSG runtime source polling owns XAML reloads instead. -->
      <Watch Remove="@(_XamlToCSharpGeneratorXamlDistinct->'%(FullPath)')" />
    </ItemGroup>
  </Target>

  <Target Name="XamlToCSharpGenerator_BuildLocalIlWeaverTask"
          Condition="'$(XamlSourceGenEnabled)' == 'true' and '$(XamlSourceGenIlWeavingEnabled)' == 'true' and !Exists('$(_XamlSourceGenPackagedIlWeaverTaskAssemblyPath)') and Exists('$(_XamlSourceGenLocalIlWeaverProjectPath)')">
    <MSBuild Projects="$(_XamlSourceGenLocalIlWeaverProjectPath)"
             Targets="Restore"
             BuildInParallel="false"
             Condition="!Exists('$(_XamlSourceGenLocalIlWeaverAssetsPath)')"
             Properties="Configuration=$(Configuration);DesignTimeBuild=false;BuildingProject=false" />

    <MSBuild Projects="$(_XamlSourceGenLocalIlWeaverProjectPath)"
             Targets="Build"
             BuildInParallel="false"
             Properties="Configuration=$(Configuration);DesignTimeBuild=false;BuildingProject=false" />
  </Target>

  <Target Name="XamlToCSharpGenerator_WeaveAvaloniaLoaderCalls"
          AfterTargets="CoreCompile"
          BeforeTargets="CopyFilesToOutputDirectory"
          DependsOnTargets="XamlToCSharpGenerator_BuildLocalIlWeaverTask"
          Condition="'$(XamlSourceGenEnabled)' == 'true' and '$(XamlSourceGenIlWeavingEnabled)' == 'true' and '$(DesignTimeBuild)' != 'true' and '@(IntermediateAssembly)' != ''">
    <Error Condition="!Exists('$(XamlSourceGenIlWeaverTaskAssemblyPath)')"
           Text="[AXSG.Build] IL weaver task assembly was not found at '$(XamlSourceGenIlWeaverTaskAssemblyPath)'." />

    <RewriteAvaloniaLoaderCallsTask AssemblyPath="@(IntermediateAssembly->'%(FullPath)')"
                                    FailOnMissingGeneratedInitializer="$(XamlSourceGenIlWeavingStrict)"
                                    DebugSymbols="$(DebugSymbols)"
                                    DebugType="$(DebugType)"
                                    AssemblyOriginatorKeyFile="$(AssemblyOriginatorKeyFile)"
                                    KeyContainerName="$(KeyContainerName)"
                                    ProjectDirectory="$(MSBuildProjectDirectory)"
                                    Verbose="$(XamlSourceGenIlWeavingVerbose)" />
  </Target>
</Project>
