<Project>
  <!-- Resolve SourceGen backend switches in .targets so project-level properties are already available. -->
  <PropertyGroup>
    <AvaloniaSourceGenCompilerEnabled Condition="'$(AvaloniaXamlCompilerBackend)' == 'SourceGen'">true</AvaloniaSourceGenCompilerEnabled>
  </PropertyGroup>

  <PropertyGroup Condition="'$(AvaloniaSourceGenCompilerEnabled)' == 'true'">
    <EnableAvaloniaXamlCompilation>false</EnableAvaloniaXamlCompilation>
    <AvaloniaNameGeneratorIsEnabled>false</AvaloniaNameGeneratorIsEnabled>
  </PropertyGroup>

  <ItemGroup Condition="'$(AvaloniaSourceGenCompilerEnabled)' == 'true' and '$(AvaloniaSourceGenTransformRules)' != ''">
    <AvaloniaSourceGenTransformRule Include="$(AvaloniaSourceGenTransformRules)" />
  </ItemGroup>

  <!-- Keep AXAML visible to Roslyn/project-system even when certain design-time IDE pipelines don't execute _InjectAdditionalFiles. -->
  <ItemGroup Condition="'$(AvaloniaSourceGenCompilerEnabled)' == 'true'">
    <_XamlToCSharpGeneratorAvaloniaXamlProjected Include="@(AvaloniaXaml)">
      <NormalizedFullPath>%(FullPath)</NormalizedFullPath>
    </_XamlToCSharpGeneratorAvaloniaXamlProjected>

    <_XamlToCSharpGeneratorTransformRuleProjected Include="@(AvaloniaSourceGenTransformRule)">
      <NormalizedFullPath>%(FullPath)</NormalizedFullPath>
    </_XamlToCSharpGeneratorTransformRuleProjected>
    <Watch Include="@(_XamlToCSharpGeneratorAvaloniaXamlProjected->'%(NormalizedFullPath)'->Distinct())">
      <XamlToCSharpGenerator>true</XamlToCSharpGenerator>
    </Watch>
    <Watch Include="@(_XamlToCSharpGeneratorTransformRuleProjected->'%(NormalizedFullPath)'->Distinct())">
      <XamlToCSharpGenerator>true</XamlToCSharpGenerator>
    </Watch>

    <CustomAdditionalCompileInputs Include="@(AvaloniaXaml)">
      <XamlToCSharpGenerator>true</XamlToCSharpGenerator>
    </CustomAdditionalCompileInputs>
    <UpToDateCheckInput Include="@(AvaloniaXaml)">
      <XamlToCSharpGenerator>true</XamlToCSharpGenerator>
    </UpToDateCheckInput>
  </ItemGroup>

  <Target Name="XamlToCSharpGenerator_PrepareCoreCompileInputs"
          BeforeTargets="CoreCompile"
          Condition="'$(AvaloniaSourceGenCompilerEnabled)' == 'true'">
    <RemoveDuplicates Inputs="@(AvaloniaXaml)">
      <Output TaskParameter="Filtered" ItemName="_XamlToCSharpGeneratorAvaloniaXamlCompileInputDistinct" />
    </RemoveDuplicates>

    <ItemGroup>
      <CustomAdditionalCompileInputs Remove="@(CustomAdditionalCompileInputs)" Condition="'%(CustomAdditionalCompileInputs.XamlToCSharpGenerator)' == 'true'" />
      <CustomAdditionalCompileInputs Include="@(_XamlToCSharpGeneratorAvaloniaXamlCompileInputDistinct)">
        <XamlToCSharpGenerator>true</XamlToCSharpGenerator>
      </CustomAdditionalCompileInputs>
    </ItemGroup>
  </Target>

  <Target Name="XamlToCSharpGenerator_CollectUpToDateCheckInputDesignTime"
          BeforeTargets="CollectUpToDateCheckInputDesignTime"
          Condition="'$(AvaloniaSourceGenCompilerEnabled)' == 'true'">
    <RemoveDuplicates Inputs="@(AvaloniaXaml)">
      <Output TaskParameter="Filtered" ItemName="_XamlToCSharpGeneratorAvaloniaXamlUpToDateDistinct" />
    </RemoveDuplicates>

    <ItemGroup>
      <UpToDateCheckInput Remove="@(UpToDateCheckInput)" Condition="'%(UpToDateCheckInput.XamlToCSharpGenerator)' == 'true'" />
      <UpToDateCheckInput Include="@(_XamlToCSharpGeneratorAvaloniaXamlUpToDateDistinct)">
        <XamlToCSharpGenerator>true</XamlToCSharpGenerator>
      </UpToDateCheckInput>
    </ItemGroup>
  </Target>

  <Target Name="XamlToCSharpGenerator_InjectAdditionalFiles"
          AfterTargets="_InjectAdditionalFiles"
          BeforeTargets="GenerateMSBuildEditorConfigFileShouldRun"
          Condition="'$(AvaloniaSourceGenCompilerEnabled)' == 'true'">
    <ItemGroup>
      <!-- Normalize all AvaloniaXaml entries into AdditionalFiles exactly once.
           This prevents duplicate AdditionalFiles under watch/re-evaluation flows. -->
      <_XamlToCSharpGeneratorAvaloniaXamlRaw Include="@(AvaloniaXaml)">
        <NormalizedIdentity>%(FullPath)</NormalizedIdentity>
      </_XamlToCSharpGeneratorAvaloniaXamlRaw>

      <_XamlToCSharpGeneratorAvaloniaXaml Include="@(_XamlToCSharpGeneratorAvaloniaXamlRaw->'%(NormalizedIdentity)')">
        <OriginalIdentity>%(_XamlToCSharpGeneratorAvaloniaXamlRaw.Identity)</OriginalIdentity>
        <Link>%(_XamlToCSharpGeneratorAvaloniaXamlRaw.Link)</Link>
        <TargetPath>%(_XamlToCSharpGeneratorAvaloniaXamlRaw.TargetPath)</TargetPath>
      </_XamlToCSharpGeneratorAvaloniaXaml>

      <_XamlToCSharpGeneratorTransformRuleRaw Include="@(AvaloniaSourceGenTransformRule)">
        <NormalizedIdentity>%(FullPath)</NormalizedIdentity>
      </_XamlToCSharpGeneratorTransformRuleRaw>

      <_XamlToCSharpGeneratorTransformRule Include="@(_XamlToCSharpGeneratorTransformRuleRaw->'%(NormalizedIdentity)')">
        <OriginalIdentity>%(_XamlToCSharpGeneratorTransformRuleRaw.Identity)</OriginalIdentity>
        <Link>%(_XamlToCSharpGeneratorTransformRuleRaw.Link)</Link>
        <TargetPath>%(_XamlToCSharpGeneratorTransformRuleRaw.TargetPath)</TargetPath>
      </_XamlToCSharpGeneratorTransformRule>
    </ItemGroup>

    <RemoveDuplicates Inputs="@(_XamlToCSharpGeneratorAvaloniaXaml)">
      <Output TaskParameter="Filtered" ItemName="_XamlToCSharpGeneratorAvaloniaXamlDistinct" />
    </RemoveDuplicates>

    <RemoveDuplicates Inputs="@(_XamlToCSharpGeneratorTransformRule)">
      <Output TaskParameter="Filtered" ItemName="_XamlToCSharpGeneratorTransformRuleDistinct" />
    </RemoveDuplicates>

    <ItemGroup>

      <!-- Drop any existing AXAML AdditionalFiles projections before re-adding deterministic entries. -->
      <AdditionalFiles Remove="@(AdditionalFiles)" Condition="'%(AdditionalFiles.SourceItemGroup)' == 'AvaloniaXaml'" />
      <AdditionalFiles Remove="@(AvaloniaXaml)" />
      <AdditionalFiles Remove="@(AvaloniaXaml->'%(FullPath)')" />
      <AdditionalFiles Remove="@(_XamlToCSharpGeneratorAvaloniaXaml->'%(NormalizedIdentity)')" />
      <AdditionalFiles Remove="@(_XamlToCSharpGeneratorAvaloniaXamlDistinct)" />
      <AdditionalFiles Remove="@(AdditionalFiles)" Condition="'%(AdditionalFiles.SourceItemGroup)' == 'AvaloniaSourceGenTransformRule'" />
      <AdditionalFiles Remove="@(AvaloniaSourceGenTransformRule)" />
      <AdditionalFiles Remove="@(AvaloniaSourceGenTransformRule->'%(FullPath)')" />
      <AdditionalFiles Remove="@(_XamlToCSharpGeneratorTransformRule->'%(NormalizedIdentity)')" />
      <AdditionalFiles Remove="@(_XamlToCSharpGeneratorTransformRuleDistinct)" />
      <AdditionalFiles Include="@(_XamlToCSharpGeneratorAvaloniaXamlDistinct)" SourceItemGroup="AvaloniaXaml">
        <Watch>false</Watch>
        <TargetPath Condition="'%(_XamlToCSharpGeneratorAvaloniaXamlDistinct.Link)' != ''">%(_XamlToCSharpGeneratorAvaloniaXamlDistinct.Link)</TargetPath>
        <TargetPath Condition="'%(_XamlToCSharpGeneratorAvaloniaXamlDistinct.Link)' == '' and '%(_XamlToCSharpGeneratorAvaloniaXamlDistinct.TargetPath)' != ''">%(_XamlToCSharpGeneratorAvaloniaXamlDistinct.TargetPath)</TargetPath>
        <TargetPath Condition="'%(_XamlToCSharpGeneratorAvaloniaXamlDistinct.Link)' == '' and '%(_XamlToCSharpGeneratorAvaloniaXamlDistinct.TargetPath)' == '' and '%(_XamlToCSharpGeneratorAvaloniaXamlDistinct.OriginalIdentity)' != ''">%(_XamlToCSharpGeneratorAvaloniaXamlDistinct.OriginalIdentity)</TargetPath>
        <TargetPath Condition="'%(_XamlToCSharpGeneratorAvaloniaXamlDistinct.Link)' == '' and '%(_XamlToCSharpGeneratorAvaloniaXamlDistinct.TargetPath)' == '' and '%(_XamlToCSharpGeneratorAvaloniaXamlDistinct.OriginalIdentity)' == ''">%(_XamlToCSharpGeneratorAvaloniaXamlDistinct.Identity)</TargetPath>
      </AdditionalFiles>
      <AdditionalFiles Include="@(_XamlToCSharpGeneratorTransformRuleDistinct)" SourceItemGroup="AvaloniaSourceGenTransformRule">
        <Watch>false</Watch>
        <TargetPath Condition="'%(_XamlToCSharpGeneratorTransformRuleDistinct.Link)' != ''">%(_XamlToCSharpGeneratorTransformRuleDistinct.Link)</TargetPath>
        <TargetPath Condition="'%(_XamlToCSharpGeneratorTransformRuleDistinct.Link)' == '' and '%(_XamlToCSharpGeneratorTransformRuleDistinct.TargetPath)' != ''">%(_XamlToCSharpGeneratorTransformRuleDistinct.TargetPath)</TargetPath>
        <TargetPath Condition="'%(_XamlToCSharpGeneratorTransformRuleDistinct.Link)' == '' and '%(_XamlToCSharpGeneratorTransformRuleDistinct.TargetPath)' == '' and '%(_XamlToCSharpGeneratorTransformRuleDistinct.OriginalIdentity)' != ''">%(_XamlToCSharpGeneratorTransformRuleDistinct.OriginalIdentity)</TargetPath>
        <TargetPath Condition="'%(_XamlToCSharpGeneratorTransformRuleDistinct.Link)' == '' and '%(_XamlToCSharpGeneratorTransformRuleDistinct.TargetPath)' == '' and '%(_XamlToCSharpGeneratorTransformRuleDistinct.OriginalIdentity)' == ''">%(_XamlToCSharpGeneratorTransformRuleDistinct.Identity)</TargetPath>
      </AdditionalFiles>

      <_XamlToCSharpGeneratorAvaloniaWatch Include="@(_XamlToCSharpGeneratorAvaloniaXamlDistinct)" />
      <_XamlToCSharpGeneratorTransformRuleWatch Include="@(_XamlToCSharpGeneratorTransformRuleDistinct)" />
      <Watch Remove="@(_XamlToCSharpGeneratorAvaloniaWatch)" />
      <Watch Remove="@(_XamlToCSharpGeneratorTransformRuleWatch)" />
      <Watch Include="@(_XamlToCSharpGeneratorAvaloniaWatch)">
        <XamlToCSharpGenerator>true</XamlToCSharpGenerator>
      </Watch>
      <Watch Include="@(_XamlToCSharpGeneratorTransformRuleWatch)">
        <XamlToCSharpGenerator>true</XamlToCSharpGenerator>
      </Watch>
    </ItemGroup>
  </Target>
</Project>
