<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:vm="clr-namespace:SourceGenCrudSample.ViewModels"
        x:Class="SourceGenCrudSample.MainWindow"
        x:DataType="vm:MainWindowViewModel"
        x:CompileBindings="True"
        Width="920"
        Height="560"
        Title="Source Generator CRUD Sample">
  <StackPanel Spacing="12">
    <TextBlock Text="People CRUD" FontSize="16" FontWeight="Bold" />
    <TextBlock Text="SourceGen backend + runtime source-generated loader" />

    <TextBlock Text="Tst" />
    <TextBlock Text="Name" />
    <TextBox Text="{Binding DraftName, Mode=TwoWay}" />

    <TextBlock Text="Email" />
    <TextBox Text="{Binding DraftEmail, Mode=TwoWay}" />

    <StackPanel Orientation="Horizontal" Spacing="8">
      <Button Width="80" Content="Add" Command="{Binding AddCommand}" />
      <Button Width="80" Content="Update" Command="{Binding UpdateCommand}" />
      <Button Width="80" Content="Delete" Command="{Binding DeleteCommand}" />
      <Button Width="80" Content="Clear" Command="{Binding ClearCommand}" />
    </StackPanel>

    <TextBlock Text="{Binding StatusMessage}" />

    <ListBox ItemsSource="{Binding People}" SelectedItem="{Binding SelectedPerson, Mode=TwoWay}">
      <ListBox.ItemTemplate>
        <DataTemplate x:DataType="vm:PersonRecord">
          <StackPanel Spacing="2">
            <TextBlock Text="{Binding Name}" />
            <TextBlock Text="{Binding Email}" />
            <TextBlock Text="{Binding Id}" />
          </StackPanel>
        </DataTemplate>
      </ListBox.ItemTemplate>
    </ListBox>
  </StackPanel>
</Window>
