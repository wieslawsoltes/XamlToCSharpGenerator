<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="clr-namespace:SourceGenCrudSample.ViewModels"
             xmlns:runtime="clr-namespace:XamlToCSharpGenerator.Runtime;assembly=XamlToCSharpGenerator.Runtime.Avalonia"
             x:Class="SourceGenCrudSample.HotDesignStudioPage"
             x:DataType="vm:HotDesignStudioViewModel"
             x:CompileBindings="False">
  <UserControl.Styles>
    <Style Selector="Border.hotdesign-toolbar">
      <Setter Property="Background" Value="#1E2130" />
      <Setter Property="Padding" Value="10" />
      <Setter Property="BorderBrush" Value="#3D6AF2" />
      <Setter Property="BorderThickness" Value="0,0,0,1" />
    </Style>
    <Style Selector="Border.hotdesign-panel">
      <Setter Property="Background" Value="#0F111A" />
      <Setter Property="BorderBrush" Value="#27304A" />
      <Setter Property="BorderThickness" Value="1" />
      <Setter Property="CornerRadius" Value="6" />
      <Setter Property="Padding" Value="8" />
    </Style>
    <Style Selector="TextBlock.hotdesign-title">
      <Setter Property="FontWeight" Value="Bold" />
      <Setter Property="Foreground" Value="#D9E2FF" />
    </Style>
    <Style Selector="TextBlock.hotdesign-meta">
      <Setter Property="Foreground" Value="#A9B5D8" />
      <Setter Property="FontSize" Value="11" />
    </Style>
  </UserControl.Styles>

  <Grid RowDefinitions="Auto,*" Margin="8" ColumnDefinitions="*">
    <Border Grid.Row="0" Classes="hotdesign-toolbar">
      <Grid ColumnDefinitions="Auto,Auto,Auto,Auto,Auto,*,Auto,Auto,Auto,Auto" ColumnSpacing="8">
        <TextBlock Grid.Column="0" Classes="hotdesign-title" VerticalAlignment="Center" Text="Hot Design Studio" />

        <ComboBox Grid.Column="1"
                  Width="130"
                  ItemsSource="{Binding WorkspaceModes}"
                  SelectedItem="{Binding WorkspaceMode, Mode=TwoWay}" />

        <ComboBox Grid.Column="2"
                  Width="120"
                  ItemsSource="{Binding PropertyFilterModes}"
                  SelectedItem="{Binding PropertyFilterMode, Mode=TwoWay}" />

        <ComboBox Grid.Column="3"
                  Width="280"
                  ItemsSource="{Binding Documents}"
                  SelectedItem="{Binding SelectedDocument, Mode=TwoWay}">
          <ComboBox.ItemTemplate>
            <DataTemplate x:DataType="runtime:SourceGenHotDesignDocumentDescriptor">
              <TextBlock Text="{Binding BuildUri}" />
            </DataTemplate>
          </ComboBox.ItemTemplate>
        </ComboBox>

        <StackPanel Grid.Column="4" Orientation="Horizontal" Spacing="6" VerticalAlignment="Center">
          <TextBlock Classes="hotdesign-meta" VerticalAlignment="Center" Text="Zoom" />
          <Slider Width="110" Minimum="0.3" Maximum="2.5" Value="{Binding Zoom, Mode=TwoWay}" />
        </StackPanel>

        <TextBox Grid.Column="5" Watermark="Search elements/toolbox" Text="{Binding SearchText, Mode=TwoWay}" />

        <Button Grid.Column="6" Content="Refresh" Command="{Binding RefreshCommand}" />
        <Button Grid.Column="7" Content="Undo" Command="{Binding UndoCommand}" />
        <Button Grid.Column="8" Content="Redo" Command="{Binding RedoCommand}" />
        <Button Grid.Column="9" Content="Apply XAML" Command="{Binding ApplyXamlCommand}" />
      </Grid>
    </Border>

    <Grid Grid.Row="1" ColumnDefinitions="340,*,360" ColumnSpacing="8" Margin="0,8,0,0">
      <Grid Grid.Column="0" RowDefinitions="*,*" RowSpacing="8">
        <Border Grid.Row="0" Classes="hotdesign-panel">
          <Grid RowDefinitions="Auto,*,Auto" RowSpacing="8">
            <TextBlock Grid.Row="0" Classes="hotdesign-title" Text="Elements" />
            <TreeView Grid.Row="1" ItemsSource="{Binding Elements}" SelectionChanged="OnElementSelectionChanged">
              <TreeView.ItemTemplate>
                <TreeDataTemplate x:DataType="runtime:SourceGenHotDesignElementNode" ItemsSource="{Binding Children}">
                  <StackPanel Orientation="Horizontal" Spacing="6">
                    <TextBlock Text="{Binding DisplayName}" />
                    <TextBlock Classes="hotdesign-meta" Text="{Binding Id}" />
                  </StackPanel>
                </TreeDataTemplate>
              </TreeView.ItemTemplate>
            </TreeView>
            <Button Grid.Row="2"
                    HorizontalAlignment="Stretch"
                    Content="Remove Selected"
                    Command="{Binding RemoveElementCommand}" />
          </Grid>
        </Border>

        <Border Grid.Row="1" Classes="hotdesign-panel">
          <Grid RowDefinitions="Auto,*,Auto,Auto" RowSpacing="8">
            <TextBlock Grid.Row="0" Classes="hotdesign-title" Text="Toolbox" />
            <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto">
              <ItemsControl ItemsSource="{Binding ToolboxCategories}">
                <ItemsControl.ItemTemplate>
                  <DataTemplate x:DataType="runtime:SourceGenHotDesignToolboxCategory">
                    <Expander Header="{Binding Name}" IsExpanded="True" Margin="0,0,0,6">
                      <ListBox ItemsSource="{Binding Items}" SelectionChanged="OnToolboxSelectionChanged">
                        <ListBox.ItemTemplate>
                          <DataTemplate x:DataType="runtime:SourceGenHotDesignToolboxItem">
                            <TextBlock Text="{Binding DisplayName}" />
                          </DataTemplate>
                        </ListBox.ItemTemplate>
                      </ListBox>
                    </Expander>
                  </DataTemplate>
                </ItemsControl.ItemTemplate>
              </ItemsControl>
            </ScrollViewer>
            <TextBox Grid.Row="2" Watermark="Element name" Text="{Binding NewElementName, Mode=TwoWay}" />
            <Button Grid.Row="3"
                    HorizontalAlignment="Stretch"
                    Content="Insert Under Selection"
                    Command="{Binding InsertElementCommand}" />
          </Grid>
        </Border>
      </Grid>

      <Border Grid.Column="1" Classes="hotdesign-panel">
        <Grid RowDefinitions="Auto,*,Auto" RowSpacing="8">
          <Grid Grid.Row="0" ColumnDefinitions="Auto,Auto,Auto,*,Auto,Auto,Auto,Auto" ColumnSpacing="6">
            <TextBlock Grid.Column="0" Classes="hotdesign-title" Text="Canvas" />
            <Button Grid.Column="1" Content="Toolbar" Command="{Binding TogglePanelCommand}" CommandParameter="Toolbar" />
            <Button Grid.Column="2" Content="Elements" Command="{Binding TogglePanelCommand}" CommandParameter="Elements" />
            <Button Grid.Column="4" Content="Toolbox" Command="{Binding TogglePanelCommand}" CommandParameter="Toolbox" />
            <Button Grid.Column="5" Content="Canvas" Command="{Binding TogglePanelCommand}" CommandParameter="Canvas" />
            <Button Grid.Column="6" Content="Properties" Command="{Binding TogglePanelCommand}" CommandParameter="Properties" />
            <TextBox Grid.Column="7" Width="100" Watermark="Form factor" Text="{Binding FormFactor, Mode=TwoWay}" />
          </Grid>

          <TextBox Grid.Row="1"
                   Text="{Binding XamlText, Mode=TwoWay}"
                   AcceptsReturn="True"
                   AcceptsTab="True"
                   HorizontalAlignment="Stretch"
                   VerticalAlignment="Stretch"
                   FontFamily="Consolas"
                   TextWrapping="NoWrap" />

          <TextBlock Grid.Row="2" Classes="hotdesign-meta" Text="{Binding StatusMessage}" TextWrapping="Wrap" />
        </Grid>
      </Border>

      <Border Grid.Column="2" Classes="hotdesign-panel">
        <Grid RowDefinitions="Auto,*,Auto,Auto,Auto,Auto" RowSpacing="8">
          <TextBlock Grid.Row="0" Classes="hotdesign-title" Text="Properties" />

          <ListBox Grid.Row="1" ItemsSource="{Binding Properties}" SelectionChanged="OnPropertySelectionChanged">
            <ListBox.ItemTemplate>
              <DataTemplate x:DataType="runtime:SourceGenHotDesignPropertyEntry">
                <Grid ColumnDefinitions="Auto,*" ColumnSpacing="8">
                  <TextBlock Text="{Binding Name}" />
                  <TextBlock Grid.Column="1" Text="{Binding Value}" Classes="hotdesign-meta" />
                </Grid>
              </DataTemplate>
            </ListBox.ItemTemplate>
          </ListBox>

          <TextBox Grid.Row="2" Watermark="Property" Text="{Binding PropertyName, Mode=TwoWay}" />
          <TextBox Grid.Row="3" Watermark="Value" Text="{Binding PropertyValue, Mode=TwoWay}" />

          <ItemsControl Grid.Row="4" ItemsSource="{Binding SelectedPropertyQuickSets}">
            <ItemsControl.ItemsPanel>
              <ItemsPanelTemplate>
                <WrapPanel />
              </ItemsPanelTemplate>
            </ItemsControl.ItemsPanel>
            <ItemsControl.ItemTemplate>
              <DataTemplate x:DataType="runtime:SourceGenHotDesignPropertyQuickSet">
                <Button Margin="0,0,6,6"
                        Content="{Binding Label}"
                        Command="{Binding $parent[UserControl].DataContext.ApplyQuickSetCommand}"
                        CommandParameter="{Binding Value}" />
              </DataTemplate>
            </ItemsControl.ItemTemplate>
          </ItemsControl>

          <StackPanel Grid.Row="5" Orientation="Horizontal" Spacing="8">
            <Button HorizontalAlignment="Stretch" Content="Apply" Command="{Binding ApplyPropertyCommand}" />
            <Button HorizontalAlignment="Stretch" Content="Remove" Command="{Binding RemovePropertyCommand}" />
          </StackPanel>
        </Grid>
      </Border>
    </Grid>
  </Grid>
</UserControl>
