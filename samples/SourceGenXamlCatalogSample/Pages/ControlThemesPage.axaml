<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:catalog="clr-namespace:SourceGenXamlCatalogSample.Catalog"
             x:Class="SourceGenXamlCatalogSample.Pages.ControlThemesPage">
  <UserControl.Resources>
    <ControlTheme x:Key="CatalogPrimaryButtonTheme" TargetType="{x:Type Button}">
      <Setter Property="Background" Value="#FF2D7FF9" />
      <Setter Property="Foreground" Value="White" />
      <Setter Property="Padding" Value="10,6" />
      <Setter Property="BorderBrush" Value="#FF2D7FF9" />
      <Setter Property="BorderThickness" Value="1" />
    </ControlTheme>

    <ControlTheme x:Key="CatalogOutlineButtonTheme"
                  TargetType="{x:Type Button}"
                  BasedOn="{StaticResource CatalogPrimaryButtonTheme}">
      <Setter Property="Background" Value="Transparent" />
      <Setter Property="Foreground" Value="#FF2D7FF9" />
    </ControlTheme>

    <ControlTheme x:Key="CatalogBadgeTheme" TargetType="{x:Type catalog:BadgeControl}">
      <Setter Property="Background" Value="#FF2D7FF9" />
      <Setter Property="Foreground" Value="White" />
      <Setter Property="Padding" Value="10,6" />
    </ControlTheme>
  </UserControl.Resources>

  <ScrollViewer>
    <StackPanel Spacing="10" Margin="8">
      <Border Classes="catalog-card">
        <StackPanel Spacing="8">
          <TextBlock FontWeight="SemiBold" Text="ControlTheme + BasedOn" />
          <StackPanel Orientation="Horizontal" Spacing="8">
            <Button Content="Primary"
                    Theme="{StaticResource CatalogPrimaryButtonTheme}" />
            <Button Content="Outline (BasedOn)"
                    Theme="{StaticResource CatalogOutlineButtonTheme}" />
          </StackPanel>
        </StackPanel>
      </Border>

      <Border Classes="catalog-card">
        <StackPanel Spacing="8">
          <TextBlock FontWeight="SemiBold" Text="ControlTheme on custom control" />
          <catalog:BadgeControl Content="BadgeControl themed via CatalogBadgeTheme"
                               Theme="{StaticResource CatalogBadgeTheme}" />
        </StackPanel>
      </Border>
    </StackPanel>
  </ScrollViewer>
</UserControl>
