<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="clr-namespace:SourceGenXamlCatalogSample.ViewModels"
             x:Class="SourceGenXamlCatalogSample.Pages.ExpressionBindingsPage"
             x:DataType="vm:ExpressionBindingsPageViewModel"
             x:CompileBindings="True">
  <UserControl.Styles>
    <Style Selector="TextBlock.expression-style" x:DataType="vm:ExpressionBindingsPageViewModel">
      <Setter Property="Text" Value="{= FirstName + ' - ' + LastName}" />
    </Style>
  </UserControl.Styles>

  <UserControl.Resources>
    <ControlTheme x:Key="ExpressionButtonTheme"
                  TargetType="{x:Type Button}"
                  x:DataType="vm:ExpressionBindingsPageViewModel">
      <Setter Property="Content" Value="{= FirstName + ' #' + Count}" />
    </ControlTheme>
  </UserControl.Resources>

  <ScrollViewer>
    <StackPanel Spacing="10" Margin="8">
      <Border Classes="catalog-card">
        <StackPanel Spacing="6" x:DataType="vm:ExpressionBindingsPageViewModel">
          <TextBlock FontWeight="SemiBold" Text="Explicit + implicit expression syntax" />
          <TextBlock Text="{= FirstName + ' ' + LastName}" />
          <TextBlock Text="{= FirstName + '!'}" />
          <TextBlock Text="{= (Count * 2) + 1}" />
          <TextBlock Text="{= Nickname ?? ('alias:' + FirstName)}" />
          <TextBlock Text="{= Tags[0] + ', ' + Tags[1]}" />
        </StackPanel>
      </Border>

      <Border Classes="catalog-card">
        <StackPanel Spacing="6" x:DataType="vm:ExpressionBindingsPageViewModel">
          <TextBlock FontWeight="SemiBold" Text="Method calls + alias operators" />
          <TextBlock Text="{= FormatSummary(FirstName, LastName, Count)}" />
          <TextBlock Text="{= (Price * (1 + TaxRate)).ToString('0.00')}" />
          <TextBlock Text="Visible when Count GT 0 AND IsAdmin"
                     IsVisible="{= Count > 0 &amp;&amp; IsAdmin}" />
        </StackPanel>
      </Border>

      <Border Classes="catalog-card">
        <StackPanel Spacing="6" x:DataType="vm:ExpressionBindingsPageViewModel">
          <TextBlock FontWeight="SemiBold" Text="Shorthand expressions + inline lambdas" />
          <TextBlock Text="{ProductName}" />
          <TextBlock Text="{$'{Quantity}x {ProductName}'}" />
          <TextBlock Text="{$'Total: ${Price * Quantity:F2}'}" />
          <TextBlock Text="{IsVip ? 'Gold Member' : 'Standard'}" />
          <TextBlock Text="Visible while not loading"
                     IsVisible="{!IsLoading}" />
          <Button Content="Submit"
                  IsEnabled="{HasAccount &amp;&amp; AgreedToTerms}" />
          <Button Content="{$'Clicked {ClickCount} times'}"
                  Click="{(s, e) => ClickCount++}" />
        </StackPanel>
      </Border>

      <Border Classes="catalog-card">
        <StackPanel Spacing="6">
          <TextBlock FontWeight="SemiBold" Text="Expression support in Style/ControlTheme setters" />
          <TextBlock Classes="expression-style" />
          <Button Theme="{StaticResource ExpressionButtonTheme}" />
        </StackPanel>
      </Border>
    </StackPanel>
  </ScrollViewer>
</UserControl>
