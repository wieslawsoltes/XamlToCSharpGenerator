<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="using:EditorAvaloniaSample.ViewModels"
             x:Class="EditorAvaloniaSample.Workspace.PreviewCardView"
             x:CompileBindings="True"
             x:DataType="vm:EditorPreviewDataViewModel">
  <ScrollViewer>
    <StackPanel Margin="16"
                Spacing="16">
      <StackPanel Spacing="4">
        <TextBlock Text="{Binding Title}"
                   FontSize="22"
                   FontWeight="SemiBold" />
        <TextBlock Text="{Binding Subtitle}"
                   Opacity="0.72"
                   TextWrapping="Wrap" />
      </StackPanel>

      <Grid ColumnDefinitions="*,Auto"
            ColumnSpacing="8">
        <TextBox Watermark="Search cards or actions"
                 Text="{Binding SearchText, Mode=TwoWay}" />
        <Button Grid.Column="1"
                Content="{Binding PrimaryActionLabel}" />
      </Grid>

      <StackPanel Spacing="6">
        <TextBlock Text="Pinned Actions"
                   FontWeight="SemiBold" />
        <Border Padding="12"
                BorderThickness="1"
                CornerRadius="8">
          <ItemsControl ItemsSource="{Binding Actions}">
            <ItemsControl.ItemTemplate>
              <DataTemplate x:DataType="vm:EditorActionItemViewModel">
                <StackPanel Margin="0,0,0,10"
                            Spacing="2">
                  <TextBlock Text="{Binding Title}"
                             FontWeight="SemiBold" />
                  <TextBlock Text="{Binding Description}"
                             Opacity="0.72"
                             TextWrapping="Wrap" />
                </StackPanel>
              </DataTemplate>
            </ItemsControl.ItemTemplate>
          </ItemsControl>
        </Border>
      </StackPanel>
    </StackPanel>
  </ScrollViewer>
</UserControl>
