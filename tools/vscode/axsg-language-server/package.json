{
  "name": "axsg-language-server",
  "displayName": "AXSG XAML Language Service",
  "description": "XAML/AXAML IntelliSense powered by XamlToCSharpGenerator.",
  "version": "0.1.0-alpha.26",
  "publisher": "wieslawsoltes",
  "license": "MIT",
  "homepage": "https://github.com/wieslawsoltes/XamlToCSharpGenerator/tree/main/tools/vscode/axsg-language-server",
  "bugs": {
    "url": "https://github.com/wieslawsoltes/XamlToCSharpGenerator/issues"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/wieslawsoltes/XamlToCSharpGenerator.git",
    "directory": "tools/vscode/axsg-language-server"
  },
  "keywords": [
    "avalonia",
    "axaml",
    "xaml",
    "language-server",
    "source-generator",
    "hot-reload"
  ],
  "icon": "media/icon.png",
  "galleryBanner": {
    "color": "#0B5CAB",
    "theme": "dark"
  },
  "engines": {
    "vscode": "^1.95.0"
  },
  "categories": [
    "Programming Languages"
  ],
  "activationEvents": [
    "workspaceContains:**/*.axaml",
    "workspaceContains:**/*.xaml"
  ],
  "main": "./extension.js",
  "contributes": {
    "languages": [
      {
        "id": "axaml",
        "aliases": [
          "AXAML",
          "axaml"
        ],
        "configuration": "./language-configuration.json",
        "extensions": [
          ".axaml"
        ]
      },
      {
        "id": "xaml",
        "aliases": [
          "XAML",
          "xaml"
        ],
        "configuration": "./language-configuration.json",
        "extensions": [
          ".xaml"
        ]
      }
    ],
    "snippets": [
      {
        "language": "axaml",
        "path": "./snippets/xaml.code-snippets"
      },
      {
        "language": "xaml",
        "path": "./snippets/xaml.code-snippets"
      }
    ],
    "semanticTokenTypes": [
      {
        "id": "xamlDelimiter",
        "description": "XAML delimiters and punctuation.",
        "superType": "operator"
      },
      {
        "id": "xamlName",
        "description": "XAML element or type names.",
        "superType": "type"
      },
      {
        "id": "xamlAttribute",
        "description": "XAML attribute names.",
        "superType": "property"
      },
      {
        "id": "xamlAttributeValue",
        "description": "XAML attribute values.",
        "superType": "string"
      },
      {
        "id": "xamlAttributeQuotes",
        "description": "XAML attribute quotes.",
        "superType": "string"
      },
      {
        "id": "xamlComment",
        "description": "XAML comments.",
        "superType": "comment"
      },
      {
        "id": "xamlKeyword",
        "description": "XAML keywords and directives.",
        "superType": "keyword"
      },
      {
        "id": "xamlMarkupExtensionClass",
        "description": "Markup extension class names.",
        "superType": "type"
      },
      {
        "id": "xamlMarkupExtensionParameterName",
        "description": "Markup extension parameter names.",
        "superType": "property"
      },
      {
        "id": "xamlMarkupExtensionParameterValue",
        "description": "Markup extension parameter values.",
        "superType": "string"
      },
      {
        "id": "xamlNamespacePrefix",
        "description": "XML namespace prefixes in XAML.",
        "superType": "namespace"
      },
      {
        "id": "xamlText",
        "description": "Text nodes in XAML.",
        "superType": "string"
      }
    ],
    "semanticTokenScopes": [
      {
        "language": "xaml",
        "scopes": {
          "xamlDelimiter": [
            "punctuation.definition.tag.xml",
            "punctuation.separator.key-value.xml"
          ],
          "xamlName": [
            "entity.name.tag.xml"
          ],
          "xamlAttribute": [
            "entity.other.attribute-name.xml"
          ],
          "xamlAttributeValue": [
            "string.quoted.double.xml",
            "string.quoted.single.xml"
          ],
          "xamlAttributeQuotes": [
            "punctuation.definition.string.begin.xml",
            "punctuation.definition.string.end.xml"
          ],
          "xamlComment": [
            "comment.block.xml"
          ],
          "xamlKeyword": [
            "keyword.other.xml"
          ],
          "xamlMarkupExtensionClass": [
            "support.class.xml",
            "entity.name.type.xml"
          ],
          "xamlMarkupExtensionParameterName": [
            "variable.parameter.xml"
          ],
          "xamlMarkupExtensionParameterValue": [
            "string.unquoted.xml"
          ],
          "xamlNamespacePrefix": [
            "entity.name.namespace.xml"
          ],
          "xamlText": [
            "text.xml"
          ]
        }
      },
      {
        "language": "axaml",
        "scopes": {
          "xamlDelimiter": [
            "punctuation.definition.tag.xml",
            "punctuation.separator.key-value.xml"
          ],
          "xamlName": [
            "entity.name.tag.xml"
          ],
          "xamlAttribute": [
            "entity.other.attribute-name.xml"
          ],
          "xamlAttributeValue": [
            "string.quoted.double.xml",
            "string.quoted.single.xml"
          ],
          "xamlAttributeQuotes": [
            "punctuation.definition.string.begin.xml",
            "punctuation.definition.string.end.xml"
          ],
          "xamlComment": [
            "comment.block.xml"
          ],
          "xamlKeyword": [
            "keyword.other.xml"
          ],
          "xamlMarkupExtensionClass": [
            "support.class.xml",
            "entity.name.type.xml"
          ],
          "xamlMarkupExtensionParameterName": [
            "variable.parameter.xml"
          ],
          "xamlMarkupExtensionParameterValue": [
            "string.unquoted.xml"
          ],
          "xamlNamespacePrefix": [
            "entity.name.namespace.xml"
          ],
          "xamlText": [
            "text.xml"
          ]
        }
      }
    ],
    "configurationDefaults": {
      "[xaml]": {
        "editor.inlayHints.enabled": "onUnlessPressed",
        "editor.semanticHighlighting.enabled": true,
        "editor.quickSuggestions": {
          "strings": "on"
        },
        "editor.semanticTokenColorCustomizations": {
          "rules": {
            "xamlDelimiter": "#0000FF",
            "xamlName": "#A31515",
            "xamlAttribute": "#FF0000",
            "xamlAttributeValue": "#0000FF",
            "xamlAttributeQuotes": "#0000FF",
            "xamlComment": "#008000",
            "xamlKeyword": "#0000FF",
            "xamlMarkupExtensionClass": "#2B91AF",
            "xamlMarkupExtensionParameterName": "#FF0000",
            "xamlMarkupExtensionParameterValue": "#0000FF",
            "xamlNamespacePrefix": "#008080",
            "number": "#098658"
          }
        }
      },
      "[axaml]": {
        "editor.inlayHints.enabled": "onUnlessPressed",
        "editor.semanticHighlighting.enabled": true,
        "editor.quickSuggestions": {
          "strings": "on"
        },
        "editor.semanticTokenColorCustomizations": {
          "rules": {
            "xamlDelimiter": "#0000FF",
            "xamlName": "#A31515",
            "xamlAttribute": "#FF0000",
            "xamlAttributeValue": "#0000FF",
            "xamlAttributeQuotes": "#0000FF",
            "xamlComment": "#008000",
            "xamlKeyword": "#0000FF",
            "xamlMarkupExtensionClass": "#2B91AF",
            "xamlMarkupExtensionParameterName": "#FF0000",
            "xamlMarkupExtensionParameterValue": "#0000FF",
            "xamlNamespacePrefix": "#008080",
            "number": "#098658"
          }
        }
      }
    },
    "configuration": {
      "title": "AXSG Language Server",
      "properties": {
        "axsg.languageServer.mode": {
          "type": "string",
          "enum": [
            "bundled",
            "custom"
          ],
          "default": "bundled",
          "description": "Language server launch mode. 'bundled' runs the managed server packaged in the extension via dotnet. 'custom' runs the command configured below."
        },
        "axsg.languageServer.command": {
          "type": "string",
          "default": "axsg-lsp",
          "description": "Path to AXSG language server command."
        },
        "axsg.languageServer.args": {
          "type": "array",
          "items": {
            "type": "string"
          },
          "default": [],
          "description": "Additional command-line arguments passed to the AXSG language server."
        },
        "axsg.languageServer.trace": {
          "type": "string",
          "enum": [
            "off",
            "messages",
            "verbose"
          ],
          "default": "off",
          "description": "Trace level for AXSG language-server protocol communication."
        },
        "axsg.inlayHints.bindingTypeHints.enabled": {
          "type": "boolean",
          "default": true,
          "description": "Show semantic type hints for compiled XAML bindings."
        },
        "axsg.inlayHints.typeDisplayStyle": {
          "type": "string",
          "enum": [
            "short",
            "qualified"
          ],
          "default": "short",
          "description": "Controls whether AXSG XAML type hints use short type names or qualified CLR names."
        },
        "axsg.preview.dotNetCommand": {
          "type": "string",
          "default": "dotnet",
          "description": "Path to the dotnet executable used for AXSG Avalonia preview build and launch steps."
        },
        "axsg.preview.compilerMode": {
          "type": "string",
          "enum": [
            "auto",
            "avalonia",
            "sourceGenerated"
          ],
          "default": "auto",
          "description": "Selects the preview compiler. 'auto' smoothly prefers AXSG source-generated preview when its runtime output is available and falls back to Avalonia when needed, 'sourceGenerated' forces the AXSG source-generated loader, and 'avalonia' uses Avalonia's XamlX previewer."
        },
        "axsg.preview.targetFramework": {
          "type": "string",
          "default": "",
          "description": "Optional target framework override used when resolving preview host and source assemblies."
        },
        "axsg.preview.hostProject": {
          "type": "string",
          "default": "",
          "description": "Optional preview host project (.csproj or folder). Use this when the current XAML file lives in a library and previewing should run against a different Avalonia executable."
        },
        "axsg.preview.buildBeforeLaunch": {
          "type": "boolean",
          "default": true,
          "description": "Build preview projects when the preview needs fresh outputs. Existing usable outputs are reused, and source-generated save refresh rebuilds only the source project when possible."
        },
        "axsg.preview.autoUpdateDelayMs": {
          "type": "number",
          "minimum": 0,
          "default": 300,
          "description": "Debounce interval, in milliseconds, before unsaved XAML edits are pushed to the Avalonia/XamlX previewer."
        }
      }
    },
    "viewsContainers": {
      "activitybar": [
        {
          "id": "axsgDesign",
          "title": "AXSG Inspector",
          "icon": "media/design.svg"
        }
      ]
    },
    "views": {
      "axsgDesign": [
        {
          "id": "axsgDesignDocumentsView",
          "name": "Documents"
        },
        {
          "id": "axsgDesignToolboxView",
          "name": "Toolbox"
        },
        {
          "id": "axsgDesignLogicalTreeView",
          "name": "Logical Tree"
        },
        {
          "id": "axsgDesignVisualTreeView",
          "name": "Visual Tree"
        },
        {
          "id": "axsgDesignPropertiesView",
          "name": "Properties",
          "type": "webview"
        }
      ]
    },
    "commands": [
      {
        "command": "axsg.languageServer.showInfo",
        "title": "AXSG: Show Language Server Info",
        "category": "AXSG"
      },
      {
        "command": "axsg.refactor.renameSymbol",
        "title": "AXSG: Rename Symbol Across C# and XAML",
        "category": "AXSG"
      },
      {
        "command": "axsg.preview.open",
        "title": "AXSG: Open Avalonia Preview",
        "category": "AXSG",
        "icon": "$(open-preview)"
      },
      {
        "command": "axsg.design.refresh",
        "title": "AXSG Inspector: Refresh",
        "category": "AXSG Inspector",
        "icon": "$(refresh)"
      },
      {
        "command": "axsg.design.focus",
        "title": "AXSG Inspector: Show Inspector Panel",
        "category": "AXSG Inspector",
        "icon": "$(layout-sidebar-left)"
      },
      {
        "command": "axsg.design.syncFromEditor",
        "title": "AXSG Inspector: Sync Selection From Editor",
        "category": "AXSG Inspector",
        "icon": "$(sync)"
      },
      {
        "command": "axsg.design.revealSelection",
        "title": "AXSG Inspector: Reveal Selection In Editor",
        "category": "AXSG Inspector",
        "icon": "$(go-to-file)"
      },
      {
        "command": "axsg.design.undo",
        "title": "AXSG Inspector: Undo",
        "category": "AXSG Inspector",
        "icon": "$(discard)"
      },
      {
        "command": "axsg.design.redo",
        "title": "AXSG Inspector: Redo",
        "category": "AXSG Inspector",
        "icon": "$(redo)"
      }
    ],
    "menus": {
      "commandPalette": [
        {
          "command": "axsg.languageServer.showInfo"
        },
        {
          "command": "axsg.preview.open"
        },
        {
          "command": "axsg.refactor.renameSymbol"
        },
        {
          "command": "axsg.design.refresh"
        },
        {
          "command": "axsg.design.focus"
        },
        {
          "command": "axsg.design.syncFromEditor"
        },
        {
          "command": "axsg.design.revealSelection"
        },
        {
          "command": "axsg.design.undo"
        },
        {
          "command": "axsg.design.redo"
        }
      ],
      "editor/context": [
        {
          "command": "axsg.preview.open",
          "when": "resourceScheme == file && editorLangId == xaml",
          "group": "navigation@10"
        },
        {
          "command": "axsg.preview.open",
          "when": "resourceScheme == file && editorLangId == axaml",
          "group": "navigation@10"
        },
        {
          "command": "axsg.refactor.renameSymbol",
          "when": "resourceScheme == file && editorLangId == csharp",
          "group": "1_modification@100"
        },
        {
          "command": "axsg.refactor.renameSymbol",
          "when": "resourceScheme == file && editorLangId == xaml",
          "group": "1_modification@100"
        },
        {
          "command": "axsg.refactor.renameSymbol",
          "when": "resourceScheme == file && editorLangId == axaml",
          "group": "1_modification@100"
        }
      ],
      "editor/title": [
        {
          "command": "axsg.preview.open",
          "when": "resourceScheme == file && editorLangId == xaml",
          "group": "navigation@10"
        },
        {
          "command": "axsg.preview.open",
          "when": "resourceScheme == file && editorLangId == axaml",
          "group": "navigation@10"
        }
      ],
      "view/title": [
        {
          "command": "axsg.design.refresh",
          "when": "view == axsgDesignDocumentsView || view == axsgDesignToolboxView || view == axsgDesignLogicalTreeView || view == axsgDesignVisualTreeView || view == axsgDesignPropertiesView",
          "group": "navigation@1"
        },
        {
          "command": "axsg.design.syncFromEditor",
          "when": "view == axsgDesignDocumentsView || view == axsgDesignToolboxView || view == axsgDesignLogicalTreeView || view == axsgDesignVisualTreeView || view == axsgDesignPropertiesView",
          "group": "navigation@2"
        },
        {
          "command": "axsg.design.revealSelection",
          "when": "view == axsgDesignLogicalTreeView || view == axsgDesignVisualTreeView || view == axsgDesignPropertiesView",
          "group": "navigation@3"
        },
        {
          "command": "axsg.design.undo",
          "when": "view == axsgDesignLogicalTreeView || view == axsgDesignVisualTreeView || view == axsgDesignPropertiesView",
          "group": "navigation@4"
        },
        {
          "command": "axsg.design.redo",
          "when": "view == axsgDesignLogicalTreeView || view == axsgDesignVisualTreeView || view == axsgDesignPropertiesView",
          "group": "navigation@5"
        }
      ]
    },
    "keybindings": [
      {
        "command": "axsg.refactor.renameSymbol",
        "key": "f2",
        "when": "editorTextFocus && resourceScheme == file && editorLangId == csharp"
      },
      {
        "command": "axsg.refactor.renameSymbol",
        "key": "f2",
        "when": "editorTextFocus && resourceScheme == file && editorLangId == xaml"
      },
      {
        "command": "axsg.refactor.renameSymbol",
        "key": "f2",
        "when": "editorTextFocus && resourceScheme == file && editorLangId == axaml"
      }
    ]
  },
  "scripts": {
    "prepare:server": "node ./scripts/prepare-server.js",
    "vscode:prepublish": "npm run prepare:server",
    "lint": "echo \"no lint configured\"",
    "package": "npx @vscode/vsce package",
    "test": "node --test ./test/*.test.js"
  },
  "dependencies": {
    "vscode-languageclient": "^9.0.1"
  },
  "devDependencies": {
    "@types/node": "^22.10.1",
    "@types/vscode": "^1.95.0",
    "@vscode/vsce": "^3.3.2"
  }
}
